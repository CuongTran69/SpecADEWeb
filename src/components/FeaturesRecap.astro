---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const colIcons: Record<string, string> = {
  'Editor': `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  'Terminal': `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M6 8l3 3-3 3"/><path d="M12 14h4"/></svg>`,
  'Workspace': `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  'Git': `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M6 9v12"/></svg>`,
  'System': `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
}

function getIcon(heading: string): string {
  for (const key of Object.keys(colIcons)) {
    if (heading.includes(key)) return colIcons[key]
  }
  return `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>`
}
---

<section class="recap" data-testid="features-recap">
  <div class="container-wide">
    <header class="recap-head">
      <h2 class="section-title">{strings.featuresRecap.title}</h2>
      <p class="section-subtitle">{strings.featuresRecap.subtitle}</p>
    </header>

    <div class="recap-grid">
      {strings.featuresRecap.columns.map((col) => (
        <div class="recap-col">
          <h3 class="recap-heading">
            <span class="recap-heading-icon" set:html={getIcon(col.heading)}></span>
            {col.heading}
          </h3>
          <div class="recap-tags">
            {col.bullets.map((bullet) => (
              <span class="recap-tag" title={bullet.desc}>{bullet.label}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .recap {
    padding-block: clamp(48px, 7vw, 80px);
    background: var(--color-bg);
  }

  .recap-head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 40px;
    max-width: 44rem;
  }

  .recap-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
  }

  @media (min-width: 640px) {
    .recap-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .recap-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1280px) {
    .recap-grid { grid-template-columns: repeat(5, 1fr); }
  }

  .recap-col {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .recap-heading {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }

  .recap-heading-icon {
    display: inline-flex;
    align-items: center;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .recap-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .recap-tag {
    display: inline-block;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: default;
    transition: color 150ms var(--ease-out-soft), border-color 150ms var(--ease-out-soft);
    white-space: nowrap;
  }

  .recap-tag:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }
</style>
