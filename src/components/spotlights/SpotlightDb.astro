---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import Spotlight from '~/components/Spotlight.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
const isVi = lang === 'vi'

const l = {
  connections: isVi ? 'KẾT NỐI' : 'CONNECTIONS',
  filterPlaceholder: isVi ? 'Tìm kiếm DB...' : 'Filter...',
  
  // Sidebar connections
  prodPg: 'prod-pg',
  stagingMysql: 'staging-mysql',
  localSqlite: 'local-sqlite',
  cacheRedis: 'cache-redis',
  analyticsMongo: 'analytics-mongo',
  
  // Connection Dialog
  addConn: isVi ? 'KẾT NỐI MỚI' : 'ADD CONNECTION',
  editMysql: isVi ? 'Cấu hình MySQL' : 'MySQL Connection',
  pasteUrl: isVi ? 'Dán chuỗi kết nối URL (Connection URL)' : 'Paste URL',
  parse: isVi ? 'Phân tích' : 'Parse',
  driver: isVi ? 'Trình điều khiển (Driver)' : 'Driver',
  dbName: isVi ? 'Tên kết nối' : 'Connection Name',
  statusColor: isVi ? 'Màu trạng thái' : 'Status color',
  host: 'Host',
  port: 'Port',
  user: isVi ? 'Người dùng' : 'User',
  password: isVi ? 'Mật khẩu' : 'Password',
  database: 'Database',
  sslMode: 'SSL Mode',
  overSsh: isVi ? 'Chạy qua SSH Tunnel' : 'Over SSH Tunnel',
  cancel: isVi ? 'Hủy' : 'Cancel',
  test: isVi ? 'Thử' : 'Test',
  save: isVi ? 'Lưu' : 'Save',
  startSimulation: isVi ? 'Bắt đầu giả lập' : 'Start Simulation',
  resetSimulation: isVi ? 'Đặt lại' : 'Reset',
  simSuccess: isVi ? '✓ Giả lập hoàn tất — Cơ sở dữ liệu đã được kết nối thành công!' : '✓ Simulation complete — Database connected successfully!',
  
  // Query view
  showUsers: 'show users with no email',
  rowsFound: isVi ? '3 dòng · 12ms' : '3 rows · 12ms',
  
  // Benefits List
  b1Title: isVi ? 'Hỗ trợ 6 Driver thông dụng' : '6 Supported Drivers',
  b1Desc: isVi ? 'Tương thích trực tiếp với PostgreSQL, MySQL, MariaDB, SQLite, MongoDB và Redis.' : 'Native compatibility with PostgreSQL, MySQL, MariaDB, SQLite, MongoDB, and Redis.',
  b2Title: isVi ? 'Trình duyệt & chỉnh sửa trực quan' : 'Visual Table Inspector & Editor',
  b2Desc: isVi ? 'Xem cấu trúc bảng, truy vấn dữ liệu và chỉnh sửa trực tiếp mà không cần công cụ ngoài.' : 'Browse tables, search records, and edit values directly within the workspace.',
  b3Title: isVi ? 'Truy vấn bằng ngôn ngữ tự nhiên' : 'AI Schema Reader & Auto-Query',
  b3Desc: isVi ? 'Tích hợp AI để tự động đọc schema, đề xuất câu lệnh SQL hoặc thực hiện migration tự động.' : 'Let AI agents read database schemas, draft queries, and run safe migration scripts.',
  b4Title: isVi ? 'Bảo mật kết nối tối đa' : 'Secure Tunneling & Safety',
  b4Desc: isVi ? 'Hỗ trợ SSH Tunnel, chế độ Safe Mode nâng cấp bảo mật khi truy cập DB production.' : 'Integrates SSH Tunneling, encrypted connection details, and production Safe Mode protection.',
}

const rows = [
  { id: '1', name: 'Alice Chen', email: 'alice@example.com', isNull: false },
  { id: '2', name: 'Bob Tran', email: 'NULL', isNull: true },
  { id: '3', name: 'Carol Pham', email: 'NULL', isNull: true },
  { id: '4', name: 'Diego Santos', email: 'NULL', isNull: true },
]
---

<section class="spotlight-section spotlight--accent" id="db">
  <div class="container-wide">
    <!-- Top Header -->
    <header class="section-head reveal">
      <span class="chip">{strings.spotlight.db.chip}</span>
      <h2 class="section-title">{strings.spotlight.db.hook}</h2>
      <p class="section-subtitle">{strings.spotlight.db.body}</p>
    </header>

    <div class="spotlight-grid">
      <!-- Left Column: Visual Mockup Container -->
      <div class="spotlight-visual reveal">
        <div class="db-mock" id="db-mock-container" data-vi={isVi ? "true" : "false"} aria-hidden="true">
          <div class="db-mock-grid">
            <!-- 1. LEFT SIDEBAR: CONNECTIONS -->
            <aside class="db-sidebar">
              <div class="sidebar-header">
                <span class="sidebar-title">{l.connections}</span>
                <button type="button" class="add-connection-btn" id="db-add-btn" title="Add Connection">+</button>
              </div>
              <div class="sidebar-search">
                <input type="text" class="search-input" placeholder={l.filterPlaceholder} readonly />
              </div>
              <div class="connection-list">
                <div class="conn-item conn-item--active" data-conn="pg">
                  <span class="status-dot dot-red"></span>
                  <div class="conn-meta">
                    <span class="conn-name">{l.prodPg}</span>
                    <span class="conn-driver">PostgreSQL</span>
                  </div>
                  <span class="tag-badge badge-prod">prod</span>
                </div>

                <div class="conn-item" data-conn="sqlite">
                  <span class="status-dot dot-green"></span>
                  <div class="conn-meta">
                    <span class="conn-name">{l.localSqlite}</span>
                    <span class="conn-driver">SQLite</span>
                  </div>
                  <span class="tag-badge badge-local">local</span>
                </div>

                <div class="conn-item" data-conn="redis">
                  <span class="status-dot dot-purple"></span>
                  <div class="conn-meta">
                    <span class="conn-name">{l.cacheRedis}</span>
                    <span class="conn-driver">Redis</span>
                  </div>
                  <span class="tag-badge badge-cache">cache</span>
                </div>

                <div class="conn-item" data-conn="mongo">
                  <span class="status-dot dot-orange"></span>
                  <div class="conn-meta">
                    <span class="conn-name">{l.analyticsMongo}</span>
                    <span class="conn-driver">MongoDB</span>
                  </div>
                  <span class="tag-badge badge-analytics">analytics</span>
                </div>
              </div>
            </aside>

            <!-- 2. MAIN DISPLAY WINDOW -->
            <main class="db-main">
              <!-- VIEW A: QUERY AND GRID -->
              <div class="db-view-panel" id="db-panel-query">
                <div class="db-chat">
                  <div class="db-bubble">
                    <span class="db-bubble-icon">›</span>
                    <span class="db-bubble-text">{l.showUsers}</span>
                    <span class="db-cursor"></span>
                  </div>
                </div>
                <div class="db-grid-wrap">
                  <div class="db-grid-meta">
                    <span class="db-table-name">users</span>
                    <span class="db-row-count">{l.rowsFound}</span>
                  </div>
                  <table class="db-grid">
                    <thead>
                      <tr>
                        <th>id</th>
                        <th>name</th>
                        <th>email</th>
                      </tr>
                    </thead>
                    <tbody>
                      {rows.map((row) => (
                        <tr class={row.isNull ? 'db-row--matched animate-pulse-light' : ''}>
                          <td class="db-cell-id">{row.id}</td>
                          <td>{row.name}</td>
                          <td>
                            {row.isNull
                              ? <span class="db-null">NULL</span>
                              : <span class="db-email">{row.email}</span>
                            }
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>

              <!-- VIEW B: CONNECTION MANAGER FORM -->
              <div class="db-view-panel" id="db-panel-form" style="display: none;">
                <div class="db-form-header">
                  <span class="form-title-text">{l.editMysql}</span>
                  <span class="form-driver-badge">MySQL</span>
                </div>
                
                <div class="db-form-body">
                  <div class="db-form-row">
                    <label class="form-field-label">{l.pasteUrl}</label>
                    <div class="url-input-group">
                      <input type="text" class="form-field-input text-muted" value="postgres://user@host:5432/db" disabled />
                      <button type="button" class="form-action-btn">{l.parse}</button>
                    </div>
                  </div>

                  <div class="db-form-grid-fields">
                    <div class="db-form-row">
                      <label class="form-field-label">{l.driver}</label>
                      <div class="custom-select-wrap">
                        <button type="button" class="select-field-btn" id="db-driver-select-btn">
                          <span>MySQL</span>
                          <span class="select-chevron">▼</span>
                        </button>
                        
                        <!-- Dropdown Menu Options (Image 3 Style) -->
                        <div class="select-dropdown-options" id="db-driver-options" style="display: none;">
                          <div class="option-item" data-value="PostgreSQL">PostgreSQL</div>
                          <div class="option-item option-item--active" data-value="MySQL">✓ MySQL</div>
                          <div class="option-item" data-value="MariaDB">MariaDB</div>
                          <div class="option-item" data-value="SQLite">SQLite</div>
                          <div class="option-item" data-value="MongoDB">MongoDB</div>
                          <div class="option-item" data-value="Redis">Redis</div>
                        </div>
                      </div>
                    </div>

                    <div class="db-form-row">
                      <label class="form-field-label">{l.dbName}</label>
                      <input type="text" class="form-field-input" value="staging-mysql" id="db-name-input" />
                    </div>
                  </div>

                  <div class="db-form-row">
                    <label class="form-field-label">{l.statusColor}</label>
                    <div class="color-picker-row">
                      <span class="color-dot dot-blue selected" data-color="blue"></span>
                      <span class="color-dot dot-pink" data-color="pink"></span>
                      <span class="color-dot dot-red" data-color="red"></span>
                      <span class="color-dot dot-orange" data-color="orange"></span>
                      <span class="color-dot dot-green" data-color="green"></span>
                      <span class="color-dot dot-cyan" data-color="cyan"></span>
                    </div>
                  </div>

                  <div class="db-form-grid-fields">
                    <div class="db-form-row">
                      <label class="form-field-label">{l.host}</label>
                      <input type="text" class="form-field-input" value="localhost" />
                    </div>
                    <div class="db-form-row">
                      <label class="form-field-label">{l.port}</label>
                      <input type="text" class="form-field-input" value="3306" id="db-port-field" />
                    </div>
                  </div>

                  <div class="db-form-checkbox-row">
                    <input type="checkbox" id="db-ssh-chk" />
                    <label for="db-ssh-chk">{l.overSsh}</label>
                  </div>
                </div>

                <div class="db-form-footer">
                  <button type="button" class="footer-btn btn-secondary" id="db-form-cancel">{l.cancel}</button>
                  <div class="right-footer-btns">
                    <button type="button" class="footer-btn btn-secondary" id="db-form-test">{l.test}</button>
                    <button type="button" class="footer-btn btn-primary" id="db-form-save">{l.save}</button>
                  </div>
                </div>
              </div>
            </main>
          </div>
        </div>

        <!-- Action Panel: Start Simulation / Success -->
        <div class="showcase-actions">
          <button type="button" class="action-btn-start" id="db-sim-btn-start">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            {l.startSimulation}
          </button>

          <div class="success-banner-card" id="db-sim-success-banner" style="display: none;">
            <span class="success-banner-text">{l.simSuccess}</span>
            <button type="button" class="action-btn-reset" id="db-sim-btn-reset">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
              {l.resetSimulation}
            </button>
          </div>
        </div>
      </div>

      <!-- Right Column: Detail Copy Lists -->
      <div class="spotlight-copy reveal">
        <div class="benefit-list">
          <div class="benefit-item">
            <h3 class="benefit-item-title">{l.b1Title}</h3>
            <p class="benefit-item-desc">{l.b1Desc}</p>
          </div>
          <div class="benefit-item">
            <h3 class="benefit-item-title">{l.b2Title}</h3>
            <p class="benefit-item-desc">{l.b2Desc}</p>
          </div>
          <div class="benefit-item">
            <h3 class="benefit-item-title">{l.b3Title}</h3>
            <p class="benefit-item-desc">{l.b3Desc}</p>
          </div>
          <div class="benefit-item">
            <h3 class="benefit-item-title">{l.b4Title}</h3>
            <p class="benefit-item-desc">{l.b4Desc}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initDbSpotlight() {
    const container = document.getElementById('db-mock-container');
    if (!container) return;

    const queryPanel = container.querySelector('#db-panel-query') as HTMLElement | null;
    const formPanel = container.querySelector('#db-panel-form') as HTMLElement | null;
    const addBtn = container.querySelector('#db-add-btn');
    
    const cancelBtn = container.querySelector('#db-form-cancel');
    const saveBtn = container.querySelector('#db-form-save');
    const testBtn = container.querySelector('#db-form-test') as HTMLButtonElement | null;
    
    const driverSelectBtn = container.querySelector('#db-driver-select-btn') as HTMLButtonElement | null;
    const driverOptions = container.querySelector('#db-driver-options') as HTMLElement | null;
    const optionItems = container.querySelectorAll('.option-item');
    const formDriverBadge = container.querySelector('.form-driver-badge') as HTMLElement | null;
    const selectLabel = driverSelectBtn?.querySelector('span') as HTMLElement | null;

    const colorDots = container.querySelectorAll('.color-dot');
    const listContainer = container.querySelector('.connection-list');
    const initialListHtml = listContainer ? listContainer.innerHTML : '';

    // Simulation Controls
    const parentSection = container.closest('.spotlight-section');
    const startBtn = parentSection?.querySelector('#db-sim-btn-start') as HTMLButtonElement | null;
    const resetBtn = parentSection?.querySelector('#db-sim-btn-reset') as HTMLButtonElement | null;
    const successBanner = parentSection?.querySelector('#db-sim-success-banner') as HTMLElement | null;

    let simTimeouts: number[] = [];
    let simRunning = false;

    // Toggle driver dropdown
    driverSelectBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (driverOptions) {
        const isShown = driverOptions.style.display === 'block';
        driverOptions.style.display = isShown ? 'none' : 'block';
      }
    });

    // Close dropdown on click outside
    document.addEventListener('click', () => {
      if (driverOptions) driverOptions.style.display = 'none';
    });

    // Select driver option
    optionItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        const value = item.getAttribute('data-value');
        if (value) {
          // Update dropdown active class
          optionItems.forEach(o => o.classList.remove('option-item--active'));
          item.classList.add('option-item--active');
          
          // Update button text and badge
          if (selectLabel) selectLabel.textContent = value;
          if (formDriverBadge) formDriverBadge.textContent = value;
          
          // Set checked indicator
          optionItems.forEach(o => {
            const val = o.getAttribute('data-value');
            o.textContent = val === value ? `✓ ${val}` : val;
          });

          // Autofill standard port based on driver
          const portField = container.querySelector('#db-port-field') as HTMLInputElement | null;
          const nameField = container.querySelector('#db-name-input') as HTMLInputElement | null;
          if (portField) {
            if (value === 'PostgreSQL') portField.value = '5432';
            else if (value === 'MySQL' || value === 'MariaDB') portField.value = '3306';
            else if (value === 'MongoDB') portField.value = '27017';
            else if (value === 'Redis') portField.value = '6379';
            else portField.value = '';
          }
          if (nameField && value) {
            nameField.value = `staging-${value.toLowerCase()}`;
          }
        }
        if (driverOptions) driverOptions.style.display = 'none';
      });
    });

    // Select color dot
    colorDots.forEach(dot => {
      dot.addEventListener('click', () => {
        colorDots.forEach(d => d.classList.remove('selected'));
        dot.classList.add('selected');
      });
    });

    function showPanel(panel: 'query' | 'form') {
      if (queryPanel) queryPanel.style.display = panel === 'query' ? 'flex' : 'none';
      if (formPanel) formPanel.style.display = panel === 'form' ? 'flex' : 'none';
    }

    addBtn?.addEventListener('click', () => {
      showPanel('form');
    });

    // Set connection list listeners initially
    function refreshListListeners() {
      if (!listContainer) return;
      const connItems = listContainer.querySelectorAll('.conn-item');
      connItems.forEach(item => {
        // Remove existing listener to prevent duplicates
        const newItem = item.cloneNode(true) as HTMLElement;
        item.parentNode?.replaceChild(newItem, item);
        
        newItem.addEventListener('click', () => {
          if (listContainer) {
            listContainer.querySelectorAll('.conn-item').forEach(i => i.classList.remove('conn-item--active'));
          }
          newItem.classList.add('conn-item--active');
          showPanel('query');
        });
      });
    }
    
    refreshListListeners();

    cancelBtn?.addEventListener('click', () => {
      showPanel('query');
    });

    saveBtn?.addEventListener('click', () => {
      // Check if connection already exists in list to prevent duplicates
      const nameInput = container.querySelector('#db-name-input') as HTMLInputElement | null;
      const connName = nameInput ? nameInput.value.trim() : 'staging-mysql';
      
      if (listContainer) {
        // Search if item with same name exists
        let exists = false;
        const currentNames = listContainer.querySelectorAll('.conn-name');
        currentNames.forEach(node => {
          if (node.textContent === connName) exists = true;
        });

        if (!exists) {
          const item = document.createElement('div');
          item.className = 'conn-item conn-item--active';
          
          // Get selected color
          const selectedColorDot = container.querySelector('.color-dot.selected');
          const colorClass = selectedColorDot ? selectedColorDot.classList[1] : 'dot-blue';
          
          // Get selected driver
          const selectedDriver = selectLabel ? selectLabel.textContent : 'MySQL';

          item.innerHTML = `
            <span class="status-dot ${colorClass}"></span>
            <div class="conn-meta">
              <span class="conn-name">${connName}</span>
              <span class="conn-driver">${selectedDriver}</span>
            </div>
            <span class="tag-badge badge-staging">staging</span>
          `;

          // Deactivate other connections
          listContainer.querySelectorAll('.conn-item').forEach(i => i.classList.remove('conn-item--active'));
          
          // Append new connection
          listContainer.appendChild(item);
          
          // Refresh click listeners on connection list
          refreshListListeners();
        } else {
          // If it exists, just activate the existing node
          listContainer.querySelectorAll('.conn-item').forEach(i => {
            const node = i.querySelector('.conn-name');
            if (node && node.textContent === connName) {
              i.classList.add('conn-item--active');
            } else {
              i.classList.remove('conn-item--active');
            }
          });
        }
      }

      showPanel('query');
    });

    testBtn?.addEventListener('click', () => {
      const isVi = container.getAttribute('data-vi') === 'true';
      const origText = testBtn.textContent;
      testBtn.textContent = isVi ? '✓ Thành công' : '✓ Connected';
      testBtn.classList.add('btn-success-green');
      setTimeout(() => {
        testBtn.textContent = origText;
        testBtn.classList.remove('btn-success-green');
      }, 1500);
    });

    // ===== Simulation Logic =====
    function schedule(fn: () => void, delay: number) {
      const id = window.setTimeout(fn, delay);
      simTimeouts.push(id);
    }

    function resetDbSimulation() {
      simTimeouts.forEach(id => clearTimeout(id));
      simTimeouts = [];
      simRunning = false;

      // Restore list HTML
      if (listContainer) {
        listContainer.innerHTML = initialListHtml;
      }
      
      // Close driver dropdown
      if (driverOptions) driverOptions.style.display = 'none';
      showPanel('query');
      
      // Restore default values in form
      const portField = container.querySelector('#db-port-field') as HTMLInputElement | null;
      const nameField = container.querySelector('#db-name-input') as HTMLInputElement | null;
      if (portField) portField.value = '3306';
      if (nameField) nameField.value = 'staging-mysql';
      if (selectLabel) selectLabel.textContent = 'MySQL';
      if (formDriverBadge) formDriverBadge.textContent = 'MySQL';
      
      // Reset option items checked indicators
      optionItems.forEach(o => {
        const val = o.getAttribute('data-value');
        o.classList.remove('option-item--active');
        if (val === 'MySQL') {
          o.classList.add('option-item--active');
          o.textContent = '✓ MySQL';
        } else {
          o.textContent = val;
        }
      });
      
      // Select blue color dot as default
      colorDots.forEach(d => d.classList.remove('selected'));
      const defaultDot = container.querySelector('.color-dot[data-color="blue"]');
      if (defaultDot) defaultDot.classList.add('selected');

      // Reset test button state if needed
      testBtn?.classList.remove('btn-success-green');

      // Reset buttons
      if (startBtn) startBtn.style.display = 'inline-flex';
      if (successBanner) {
        successBanner.hidden = true;
        successBanner.style.display = 'none';
      }

      refreshListListeners();
    }

    function runDbSimulation() {
      if (simRunning) return;
      simRunning = true;

      if (startBtn) startBtn.style.display = 'none';
      if (successBanner) {
        successBanner.hidden = true;
        successBanner.style.display = 'none';
      }

      // Step 1: Click "+" button after 600ms
      schedule(() => {
        addBtn?.dispatchEvent(new Event('click'));
      }, 600);

      // Step 2: Open driver select dropdown after 1800ms
      schedule(() => {
        driverSelectBtn?.dispatchEvent(new Event('click'));
      }, 1800);

      // Step 3: Choose PostgreSQL after 3000ms
      schedule(() => {
        const pgOption = container.querySelector('.option-item[data-value="PostgreSQL"]') as HTMLElement | null;
        if (pgOption) {
          pgOption.dispatchEvent(new Event('click'));
        }
      }, 3000);

      // Step 4: Click green status color dot after 4200ms
      schedule(() => {
        const greenDot = container.querySelector('.color-dot[data-color="green"]') as HTMLElement | null;
        if (greenDot) {
          greenDot.dispatchEvent(new Event('click'));
        }
      }, 4200);

      // Step 5: Click Test after 5400ms
      schedule(() => {
        testBtn?.dispatchEvent(new Event('click'));
      }, 5400);

      // Step 6: Click Save after 7400ms
      schedule(() => {
        saveBtn?.dispatchEvent(new Event('click'));
      }, 7400);

      // Step 7: Finish simulation and show success banner after 8600ms
      schedule(() => {
        simRunning = false;
        if (successBanner) {
          successBanner.hidden = false;
          successBanner.style.display = 'flex';
        }
      }, 8600);
    }

    startBtn?.addEventListener('click', runDbSimulation);
    resetBtn?.addEventListener('click', resetDbSimulation);
  }

  initDbSpotlight();
  document.addEventListener('astro:after-swap', initDbSpotlight);
</script>

<style>
  .spotlight-section {
    padding-block: clamp(64px, 8vw, 100px);
    border-block-end: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .spotlight--accent {
    background: var(--color-surface);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 36px;
    max-width: 44rem;
  }

  .spotlight-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .spotlight-grid {
