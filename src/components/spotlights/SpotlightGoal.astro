---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'
import Spotlight from '~/components/Spotlight.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const lines = [
  { prefix: '›', text: 'Goal: "Add login form with validation"', cls: 'line-prompt' },
  { prefix: '›', text: 'Criterion: "All tests pass"', cls: 'line-prompt' },
  { prefix: '◆', text: 'Iteration 1 — implementing...', cls: 'line-claude' },
  { prefix: '◇', text: 'Watcher: <action>continue</action>', cls: 'line-watcher' },
  { prefix: '◆', text: 'Iteration 2 — adding tests...', cls: 'line-claude' },
  { prefix: '◇', text: 'Watcher: <action>continue</action>', cls: 'line-watcher' },
  { prefix: '◆', text: 'Iteration 3 — fixing failures...', cls: 'line-claude' },
  { prefix: '◇', text: 'Watcher: <action>complete</action>', cls: 'line-watcher' },
  { prefix: '✓', text: 'Goal achieved · 3 iterations · 0 user prompts', cls: 'line-success' },
]
---

<Spotlight id="goal" hook={strings.spotlight.goal.hook} body={strings.spotlight.goal.body} tone="accent" flip>
  <div slot="visual" class="goal-terminal" aria-hidden="true">
    <div class="goal-dots">
      <span class="goal-dot dot-red"></span>
      <span class="goal-dot dot-amber"></span>
      <span class="goal-dot dot-green"></span>
      <span class="goal-title">goalrunner --watch</span>
    </div>
    <div class="goal-timeline-container">
      <div class="goal-timeline-line"></div>
      <ul class="goal-lines">
        {lines.map((line, i) => {
          let text = line.text;
          if (line.cls === 'line-watcher') {
            text = line.text.replace('<action>', '<span class="watcher-action">').replace('</action>', '</span>');
          }
          return (
            <li class={`goal-line ${line.cls}`} style={`--i: ${i}`}>
              <div class="goal-node">
                <span class="goal-node-prefix">{line.prefix}</span>
              </div>
              <div class="goal-content">
                <span class="goal-text" set:html={text}></span>
              </div>
            </li>
          )
        })}
      </ul>
    </div>
  </div>
  <a slot="extra" href={pathFor(lang, '/features#goal-showcase')} class="btn btn-secondary" style="margin-top: 8px;">
    {strings.spotlight.goal.viewDetailBtn}
  </a>
</Spotlight>

<style>
  .goal-terminal {
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 13px;
    box-sizing: border-box;
  }

  .goal-dots {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: var(--color-raised);
    border-bottom: 1px solid var(--color-border-strong);
    user-select: none;
  }

  .goal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-amber { background: #febc2e; }
  .dot-green { background: #28c840; }

  .goal-title {
    margin-left: 12px;
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .goal-timeline-container {
    position: relative;
    padding: 24px 20px;
    background: color-mix(in srgb, var(--color-bg) 20%, var(--color-surface));
  }

  .goal-timeline-line {
    position: absolute;
    top: 24px;
    bottom: 24px;
    left: 28px;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      var(--color-border-strong) 0px,
      var(--color-border-strong) 4px,
      transparent 4px,
      transparent 8px
    );
  }

  .goal-lines {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
  }

  .goal-line {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    opacity: 0;
    animation: line-in 350ms var(--ease-out-soft) backwards;
    animation-delay: calc(var(--i) * 360ms);
    will-change: opacity, transform;
  }

  .goal-node {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-raised);
    border: 1px solid var(--color-border-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
    transition: border-color 200ms var(--ease-out-soft), background-color 200ms var(--ease-out-soft);
  }

  .goal-node-prefix {
    font-size: 10px;
    font-weight: bold;
    color: var(--color-text-muted);
  }

  .goal-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 1px;
  }

  .goal-text {
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Node customization based on step class */
  .line-prompt .goal-node {
    border-color: var(--color-accent);
    background-color: var(--color-accent-soft);
  }
  .line-prompt .goal-node-prefix {
    color: var(--color-accent);
  }

  .line-claude .goal-node {
    border-color: var(--color-claude);
    background-color: color-mix(in srgb, var(--color-claude) 15%, transparent);
    animation: pulse-node 2s infinite alternate;
  }
  .line-claude .goal-node-prefix {
    color: var(--color-claude);
  }
  .line-claude .goal-text {
    color: var(--color-text);
  }

  .line-watcher {
    padding-left: 12px;
  }
  .line-watcher .goal-node {
    border-color: var(--color-warning);
    background-color: color-mix(in srgb, var(--color-warning) 12%, transparent);
  }
  .line-watcher .goal-node-prefix {
    color: var(--color-warning);
  }
  .line-watcher .goal-text {
    font-size: 12px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .line-watcher :global(.watcher-action) {
    font-weight: bold;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 1px 6px;
    border-radius: var(--radius-xs);
    background: color-mix(in srgb, var(--color-warning) 20%, transparent);
    color: var(--color-warning);
  }

  .line-success .goal-node {
    border-color: var(--color-success);
    background-color: color-mix(in srgb, var(--color-success) 20%, transparent);
  }
  .line-success .goal-node-prefix {
    color: var(--color-success);
  }
  .line-success .goal-text {
    color: var(--color-success);
    font-weight: 600;
    background: color-mix(in srgb, var(--color-success) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-success) 25%, transparent);
    padding: 8px 12px;
    border-radius: var(--radius-md);
    width: 100%;
    box-sizing: border-box;
  }

  @keyframes pulse-node {
    from { transform: scale(1); }
    to { transform: scale(1.1); }
  }

  @keyframes line-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .goal-line {
      animation: none;
      opacity: 1;
    }
    .line-claude .goal-node {
      animation: none;
    }
  }
</style>
