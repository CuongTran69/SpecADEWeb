---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import Spotlight from '~/components/Spotlight.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const platforms = [
  { id: 'macos', label: 'macOS', sub: 'launchd', pos: 'top-left' },
  { id: 'windows', label: 'Windows', sub: 'Task Scheduler', pos: 'top-right' },
  { id: 'linux', label: 'Linux', sub: 'systemd', pos: 'bottom-left' },
  { id: 'vps', label: 'VPS / Cloud', sub: 'user service', pos: 'bottom-right' },
]
---

<Spotlight id="binary" hook={strings.spotlight.binary.hook} body={strings.spotlight.binary.body} tone="default">
  <div slot="visual" class="binary-diagram" aria-hidden="true">
    <div class="binary-grid">
      <div class="platform-card platform-top-left">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/>
          <path d="M10 2c0 2.5.5 4 2 4"/>
        </svg>
        <span class="platform-label">macOS</span>
        <span class="platform-sub">launchd</span>
      </div>
      <div class="platform-card platform-top-right">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <path d="M8 21h8M12 17v4"/>
        </svg>
        <span class="platform-label">Windows</span>
        <span class="platform-sub">Task Scheduler</span>
      </div>
      <div class="binary-center">
        <div class="binary-cube">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <!-- cube front face -->
            <polygon points="32,8 56,20 56,44 32,56 8,44 8,20" fill="none" stroke="currentColor" opacity="0.3"/>
            <!-- cube top face -->
            <polygon points="32,8 56,20 32,32 8,20" fill="none" stroke="currentColor" opacity="0.5"/>
            <!-- cube left face -->
            <polygon points="8,20 32,32 32,56 8,44" fill="none" stroke="currentColor" opacity="0.2"/>
            <!-- cube right face -->
            <polygon points="56,20 32,32 32,56 56,44" fill="none" stroke="currentColor" opacity="0.35"/>
            <!-- vertical center line -->
            <line x1="32" y1="8" x2="32" y2="32"/>
            <line x1="32" y1="32" x2="32" y2="56"/>
          </svg>
          <span class="cube-label">spec-ade</span>
        </div>
      </div>
      <div class="platform-card platform-bottom-left">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
          <path d="M2 12h20"/>
        </svg>
        <span class="platform-label">Linux</span>
        <span class="platform-sub">systemd</span>
      </div>
      <div class="platform-card platform-bottom-right">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="8" rx="2"/>
          <rect x="2" y="14" width="20" height="8" rx="2"/>
          <path d="M6 6h.01M6 18h.01"/>
        </svg>
        <span class="platform-label">VPS / Cloud</span>
        <span class="platform-sub">user service</span>
      </div>
    </div>
    <!-- SVG arrows overlay -->
    <svg class="binary-arrows" viewBox="0 0 320 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- top-left arrow -->
      <line class="arrow-line" x1="160" y1="120" x2="60" y2="50" stroke="currentColor" stroke-width="1.5" stroke-dasharray="6 4"/>
      <!-- top-right arrow -->
      <line class="arrow-line" x1="160" y1="120" x2="260" y2="50" stroke="currentColor" stroke-width="1.5" stroke-dasharray="6 4"/>
      <!-- bottom-left arrow -->
      <line class="arrow-line" x1="160" y1="120" x2="60" y2="190" stroke="currentColor" stroke-width="1.5" stroke-dasharray="6 4"/>
      <!-- bottom-right arrow -->
      <line class="arrow-line" x1="160" y1="120" x2="260" y2="190" stroke="currentColor" stroke-width="1.5" stroke-dasharray="6 4"/>
    </svg>
  </div>
</Spotlight>

<style>
  .binary-diagram {
    position: relative;
    padding: 16px;
  }

  .binary-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto auto;
    gap: 16px;
    align-items: center;
    justify-items: center;
  }

  .platform-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 10px 14px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    min-width: 90px;
    text-align: center;
  }

  .platform-top-left { grid-column: 1; grid-row: 1; }
  .platform-top-right { grid-column: 3; grid-row: 1; }
  .binary-center { grid-column: 2; grid-row: 1 / 3; }
  .platform-bottom-left { grid-column: 1; grid-row: 3; }
  .platform-bottom-right { grid-column: 3; grid-row: 3; }

  .platform-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text);
  }

  .platform-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-muted);
  }

  .binary-center {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .binary-cube {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: var(--color-accent);
  }

  .cube-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.04em;
  }

  .binary-arrows {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    color: var(--color-accent);
    opacity: 0.4;
  }

  .arrow-line {
    stroke-dasharray: 6 4;
    animation: dash-draw 2s linear infinite;
  }

  @keyframes dash-draw {
    from { stroke-dashoffset: 20; }
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow-line {
      animation: none;
      stroke-dasharray: none;
    }
  }
</style>
