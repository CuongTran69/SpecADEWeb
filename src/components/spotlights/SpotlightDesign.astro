<script>
  function initDesignSpotlight() {
    const container = document.getElementById('design-mock-container');
    if (!container) return;

    const isVi = container.getAttribute('data-vi') === 'true';
    const views = container.querySelectorAll('.design-view');
    const tabs = container.querySelectorAll('.design-tab');
    const selectBtn = container.querySelector('#design-sys-dropdown-btn') as HTMLElement | null;
    const selectOptions = container.querySelector('#design-sys-options') as HTMLElement | null;
    const selectedSysText = container.querySelector('#design-selected-sys') as HTMLElement | null;
    const optItems = container.querySelectorAll('.design-opt-item');
    const fidelityCards = container.querySelectorAll('.fidelity-card');
    const createBtn = container.querySelector('#design-btn-create') as HTMLButtonElement | null;
    const projNameInput = container.querySelector('#design-proj-name') as HTMLInputElement | null;
    const projectsList = container.querySelector('#design-projects-list');

    // Example panel trigger
    const usePromptBtn = container.querySelector('#btn-use-example-prompt');

    // Pets & Sidebars
    const mockGrid = container.querySelector('#design-mock-grid') as HTMLElement | null;
    const changePetBtn = container.querySelector('#btn-change-pet') as HTMLButtonElement | null;
    const closePetsBtn = container.querySelector('#close-pets-btn') as HTMLElement | null;
    const tuckAwayBtn = container.querySelector('#btn-tuck-away') as HTMLButtonElement | null;
    const floatingBuddy = container.querySelector('#design-floating-buddy') as HTMLElement | null;
    const tuckText = tuckAwayBtn?.querySelector('.tuck-text') as HTMLElement | null;

    // Simulation controls
    const parentSection = container.closest('.spotlight-section');
    const startBtn = parentSection?.querySelector('#design-sim-btn-start') as HTMLButtonElement | null;
    const resetBtn = parentSection?.querySelector('#design-sim-btn-reset') as HTMLButtonElement | null;
    const successBanner = parentSection?.querySelector('#design-sim-success-banner') as HTMLElement | null;

    let simTimeouts: number[] = [];
    let simRunning = false;
    const initialProjectsHtml = projectsList ? projectsList.innerHTML : '';

    // Switch views tab helper
    function switchViewTab(tabName: string) {
      tabs.forEach(tab => {
        const isActive = tab.getAttribute('data-tab') === tabName;
        tab.classList.toggle('active', isActive);
      });

      views.forEach(view => {
        const id = view.getAttribute('id');
        const matches = id === `view-${tabName}`;
        view.style.display = matches ? 'block' : 'none';
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const tabName = tab.getAttribute('data-tab');
        if (tabName) switchViewTab(tabName);
      });
    });

    // Dropdown toggle
    selectBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (selectOptions) {
        selectOptions.style.display = selectOptions.style.display === 'block' ? 'none' : 'block';
      }
    });

    document.addEventListener('click', () => {
      if (selectOptions) selectOptions.style.display = 'none';
    });

    // Select options click
    optItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        const val = item.getAttribute('data-val');
        if (val && selectedSysText) {
          selectedSysText.textContent = val;
          optItems.forEach(opt => opt.classList.remove('active'));
          item.classList.add('active');
        }
        if (selectOptions) selectOptions.style.display = 'none';
      });
    });

    // Select fidelity card click
    fidelityCards.forEach(card => {
      card.addEventListener('click', () => {
        fidelityCards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
    });

    // Use this prompt example
    function applyExamplePrompt() {
      if (projNameInput) {
        projNameInput.value = 'Open Design Landing';
        projNameInput.classList.add('saved-pulse');
        setTimeout(() => projNameInput.classList.remove('saved-pulse'), 1000);
      }

      // Set Design System to Neutral Modern
      if (selectedSysText) selectedSysText.textContent = 'Neutral Modern';
      optItems.forEach(opt => {
        const val = opt.getAttribute('data-val');
        opt.classList.toggle('active', val === 'Neutral Modern');
      });

      // Set fidelity to High fidelity
      fidelityCards.forEach(c => {
        c.classList.toggle('active', c.getAttribute('id') === 'fid-hifi');
      });
    }

    usePromptBtn?.addEventListener('click', applyExamplePrompt);

    // Create Design Button
    function createNewDesign() {
      const name = projNameInput?.value.trim() || 'Untitled Prototype';
      
      if (projectsList) {
        // Prevent duplicate creation in list
        let exists = false;
        projectsList.querySelectorAll('.folder-name').forEach(el => {
          if (el.textContent === name) exists = true;
        });

        if (!exists) {
          const card = document.createElement('div');
          card.className = 'design-folder-card active-pulse';
          
          const selectedSys = selectedSysText ? selectedSysText.textContent : 'Neutral Modern';
          const fidCard = container?.querySelector('.fidelity-card.active');
          const isHifi = fidCard?.getAttribute('id') === 'fid-hifi';
          const detailsText = `${selectedSys} - ${isHifi ? 'high-fidelity' : 'wireframe'} - Active`;

          card.innerHTML = `
            <div class="folder-icon" style="color: var(--color-accent);">📁</div>
            <h4 class="folder-name">${name}</h4>
            <p class="folder-meta">${detailsText}</p>
          `;

          // Put it at the top of the list
          projectsList.insertBefore(card, projectsList.firstChild);
          setTimeout(() => card.classList.remove('active-pulse'), 1200);
        }
      }

      switchViewTab('designs');
    }

    createBtn?.addEventListener('click', createNewDesign);

    // Change pet interaction
    changePetBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      mockGrid?.classList.toggle('show-pets');
    });

    closePetsBtn?.addEventListener('click', () => {
      mockGrid?.classList.remove('show-pets');
    });

    // Tuck away pet interaction
    tuckAwayBtn?.addEventListener('click', () => {
      const isTucked = floatingBuddy?.classList.toggle('tucked');
      if (tuckText) {
        if (isTucked) {
          tuckText.textContent = isVi ? 'Hiện pet' : 'Show pet';
        } else {
          tuckText.textContent = isVi ? 'Ẩn pet' : 'Tuck away';
        }
      }
    });

    // ===== Simulation Logic =====
    function schedule(fn: () => void, delay: number) {
      const id = window.setTimeout(fn, delay);
      simTimeouts.push(id);
    }

    function resetDesignSimulation() {
      simTimeouts.forEach(id => clearTimeout(id));
      simTimeouts = [];
      simRunning = false;

      // Restore list
      if (projectsList) projectsList.innerHTML = initialProjectsHtml;

      // Restore inputs
      if (projNameInput) projNameInput.value = '';
      if (selectedSysText) selectedSysText.textContent = 'Neutral Modern';
      optItems.forEach(o => {
        o.classList.toggle('active', o.getAttribute('data-val') === 'Neutral Modern');
      });
      fidelityCards.forEach(c => {
        c.classList.toggle('active', c.getAttribute('id') === 'fid-hifi');
      });

      // Switch to Designs tab & hide pets sidebar
      switchViewTab('designs');
      mockGrid?.classList.remove('show-pets');

      // Reset buttons
      if (startBtn) startBtn.style.display = 'inline-flex';
      if (successBanner) {
        successBanner.hidden = true;
        successBanner.style.display = 'none';
      }
    }

    function runDesignSimulation() {
      if (simRunning) return;
      simRunning = true;

      if (startBtn) startBtn.style.display = 'none';
      if (successBanner) {
        successBanner.hidden = true;
        successBanner.style.display = 'none';
      }

      // Step 1: Switch to Examples tab (800ms) and open pets sidebar
      schedule(() => {
        switchViewTab('examples');
        mockGrid?.classList.add('show-pets');
      }, 800);

      // Step 2: Click "Use this prompt" on the example (2200ms)
      schedule(() => {
        const promptBtn = container.querySelector('#btn-use-example-prompt') as HTMLElement | null;
        promptBtn?.dispatchEvent(new Event('click'));
      }, 2200);

      // Step 3: Trigger the Create button click (3700ms)
      schedule(() => {
        createBtn?.dispatchEvent(new Event('click'));
      }, 3700);

      // Step 4: Show success banner after returning to Designs panel (5000ms) and close pets sidebar
      schedule(() => {
        simRunning = false;
        mockGrid?.classList.remove('show-pets');
        if (successBanner) {
          successBanner.hidden = false;
          successBanner.style.display = 'flex';
        }
      }, 5000);
    }

    startBtn?.addEventListener('click', runDesignSimulation);
    resetBtn?.addEventListener('click', resetDesignSimulation);
  }

  initDesignSpotlight();
  document.addEventListener('astro:after-swap', initDesignSpotlight);
</script>

