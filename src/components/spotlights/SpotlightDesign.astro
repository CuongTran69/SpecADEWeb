---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
const isVi = lang === 'vi'

const l = {
  tabDesigns: 'Designs',
  tabExamples: 'Examples',
  tabDesignSystems: 'Design systems',
  tabConnectors: 'Connectors',
  tabImageTemplates: 'Image templates',
  tabVideoTemplates: 'Video templates',
  
  // Left Sidebar Form
  newPrototype: isVi ? 'PROTOTYPE MỚI' : 'NEW PROTOTYPE',
  projectNameLabel: isVi ? 'Tên dự án' : 'Project name',
  designSystemLabel: isVi ? 'Hệ thống thiết kế' : 'Design system',
  fidelityLabel: isVi ? 'Độ chi tiết (Fidelity)' : 'Fidelity',
  wireframe: isVi ? 'Bản phác thảo' : 'Wireframe',
  highFidelity: isVi ? 'Mẫu chi tiết' : 'High fidelity',
  btnCreate: isVi ? '+ Tạo thiết kế' : '+ Create',
  btnImport: isVi ? 'Nhập tệp ZIP thiết kế từ Claude' : 'Import Claude Design ZIP',
  visibilityText: isVi ? 'Mặc định chỉ bạn mới có thể xem dự án.' : 'Only you can see your project by default.',
  
  // Simulation text
  startSimulation: isVi ? 'Bắt đầu giả lập' : 'Start Simulation',
  resetSimulation: isVi ? 'Đặt lại' : 'Reset',
  simSuccess: isVi ? '✓ Giả lập hoàn tất — Bản thiết kế mẫu đã được khởi tạo thành công!' : '✓ Simulation complete — Prototype created successfully!',
  
  // Examples
  useThisPrompt: isVi ? 'Sử dụng prompt này' : 'Use this prompt',
  openPreview: isVi ? 'Xem trước' : 'Open preview',
  share: isVi ? 'Chia sẻ' : 'Share',
  
  // Benefits List
  b1Title: isVi ? 'Prompt Mẫu (Prompt Examples)' : 'Prompt Examples',
  b1Desc: isVi ? 'Thư viện prompt tối ưu cho landing page, slide thuyết trình, ứng dụng di động hay giao diện phức tạp để thiết kế chỉ trong tích tắc.' : 'A rich library of production-tested prompts for landing pages, slide decks, mobile layouts, and complex interfaces to start designing in seconds.',
  b2Title: isVi ? 'Hệ thống thiết kế (Design Systems)' : 'Design Systems',
  b2Desc: isVi ? 'Đồng bộ hóa typography, bảng màu và bộ kit UI riêng giúp đảm bảo giao diện tạo ra luôn đồng nhất với nhận diện thương hiệu.' : 'Synchronize typography, palettes, and custom UI kits so that generated interfaces always align with your design guidelines.',
  b3Title: isVi ? 'Thư viện mẫu ảnh (Image Templates)' : 'Image Templates',
  b3Desc: isVi ? 'Tích hợp sẵn các template tạo infographic 3D, ảnh minh họa game, thiết kế phong cách anime hay giao diện live-stream e-commerce từ mô tả văn bản.' : 'Built-in templates to generate 3D infographics, game illustrations, anime art, and e-commerce live-stream interfaces directly from text prompts.',
  b4Title: isVi ? 'Thư viện mẫu video (Video Templates)' : 'Video Templates',
  b4Desc: isVi ? 'Tạo video thuyết trình thuyết phục với người dẫn ảo AI (AI Presenter) hoặc các clip quảng bá sản phẩm dạng motion loop mượt mà chỉ bằng một cú click.' : 'Create compelling product presentations using AI avatar presenters or sleek motion graphic loop clips to showcase your application.',
}
---

<section class="spotlight-section spotlight--accent" id="design">
  <div class="container-wide">
    <!-- Top Header -->
    <header class="section-head reveal">
      <span class="chip">{strings.spotlight.design.chip}</span>
      <h2 class="section-title">{strings.spotlight.design.hook}</h2>
      <p class="section-subtitle">{strings.spotlight.design.body}</p>
    </header>

    <div class="spotlight-grid">
      <!-- Left Column: Visual Mockup Container -->
      <div class="spotlight-visual reveal">
        <div class="design-mock" id="design-mock-container" data-vi={isVi ? "true" : "false"} aria-hidden="true">
          
          <!-- Mockup Top Bar -->
          <div class="design-mock-top">
            <div class="design-logo-area">
              <span class="design-logo-icon">🎨</span>
              <span class="design-logo-text">Open Design</span>
            </div>
            <div class="design-top-right">
              <span class="settings-gear">⚙️</span>
            </div>
          </div>

          <div class="design-mock-grid" id="design-mock-grid">
            <!-- 1. LEFT SIDEBAR: CREATOR PANEL -->
            <aside class="design-sidebar">
              <div class="design-sidebar-tabs">
                <span class="sidebar-tab active">Prototype</span>
                <span class="sidebar-tab">Live artifact</span>
                <span class="sidebar-tab">Slide deck</span>
                <span class="sidebar-tab scroll-fade">From temp...</span>
              </div>
              
              <div class="design-form-box">
                <div class="form-title">{l.newPrototype}</div>
                
                <div class="form-group">
                  <label class="form-label">{l.projectNameLabel}</label>
                  <input type="text" class="design-input" id="design-proj-name" placeholder="e.g. Spec ADE Landing" />
                </div>
                
                <div class="form-group">
                  <label class="form-label">{l.designSystemLabel}</label>
                  <div class="design-select-btn" id="design-sys-dropdown-btn">
                    <span id="design-selected-sys">Neutral Modern</span>
                    <span class="chevron">▼</span>
                  </div>
                  <!-- Dropdown options -->
                  <div class="design-dropdown-options" id="design-sys-options" style="display: none;">
                    <div class="design-opt-item active" data-val="Neutral Modern">Neutral Modern</div>
                    <div class="design-opt-item" data-val="Terminal Dark">Terminal Dark</div>
                    <div class="design-opt-item" data-val="Glassmorphism">Glassmorphism</div>
                    <div class="design-opt-item" data-val="Neon Cyberpunk">Neon Cyberpunk</div>
                  </div>
                </div>

                <div class="form-group">
                  <label class="form-label">{l.fidelityLabel}</label>
                  <div class="fidelity-cards">
                    <div class="fidelity-card" id="fid-wireframe">
                      <div class="fid-icon fid-wire-icon">
                        <span></span><span></span><span></span>
                      </div>
                      <span class="fid-label">{l.wireframe}</span>
                    </div>
                    <div class="fidelity-card active" id="fid-hifi">
                      <div class="fid-icon fid-hifi-icon">
                        <span></span><span></span><span></span>
                      </div>
                      <span class="fid-label">{l.highFidelity}</span>
                    </div>
                  </div>
                </div>

                <button type="button" class="btn-create-design" id="design-btn-create">{l.btnCreate}</button>
                
                <div class="btn-import-zip">
                  <span class="zip-icon">📁</span>
                  <span>{l.btnImport}</span>
                </div>

                <p class="visibility-note">{l.visibilityText}</p>
              </div>

              <!-- Bottom sidebar meta (Change Pet and CLI version) -->
              <div class="design-sidebar-footer">
                <button type="button" class="btn-change-pet" id="btn-change-pet">
                  <span>🦄</span>
                  <span>Change pet</span>
                </button>
                <div class="footer-meta-item dim">Local CLI · Claude Code - 2.1.133 [Claude ..</div>
                <div class="footer-meta-item dim">Follow @nexudotio</div>
                <div class="footer-meta-item dim select-lang-meta">
                  <span>🌐 English</span>
                  <span class="chevron">▼</span>
                </div>
              </div>
            </aside>

            <!-- 2. MAIN HUB WORKSPACE -->
            <main class="design-main">
              <!-- Tab bar navigation -->
              <div class="design-tabs">
                <button type="button" class="design-tab active" data-tab="designs">{l.tabDesigns}</button>
                <button type="button" class="design-tab" data-tab="examples">{l.tabExamples}</button>
                <button type="button" class="design-tab" data-tab="design-systems">{l.tabDesignSystems}</button>
                <button type="button" class="design-tab" data-tab="connectors">{l.tabConnectors}</button>
                <button type="button" class="design-tab" data-tab="image-templates">{l.tabImageTemplates}</button>
                <button type="button" class="design-tab" data-tab="video-templates">{l.tabVideoTemplates}</button>
              </div>

              <!-- Content views -->
              <div class="design-content-area">
                
                <!-- VIEW A: DESIGNS PANEL (Active by default) -->
                <div class="design-view" id="view-designs">
                  <div class="designs-header">
                    <div class="sub-tabs">
                      <span class="sub-tab active">Recent</span>
                      <span class="sub-tab">Your designs</span>
                    </div>
                    <div class="search-bar-wrap">
                      <input type="text" class="search-input" placeholder="Search..." readonly />
                    </div>
                  </div>

                  <div class="designs-grid" id="design-projects-list">
                    <!-- Card 1 -->
                    <div class="design-folder-card">
                      <div class="folder-icon">📁</div>
                      <h4 class="folder-name">Prototype - 5/18/2026</h4>
                      <p class="folder-meta">Neutral Modern - blog-post - <span class="state-not">Not st...</span></p>
                    </div>

                    <!-- Card 2 -->
                    <div class="design-folder-card">
                      <div class="folder-icon">📁</div>
                      <h4 class="folder-name">Prototype - 5/18/2026</h4>
                      <p class="folder-meta">Neutral Modern - blog-post - <span class="state-comp">Comp...</span></p>
                    </div>
                  </div>
                </div>

                <!-- VIEW B: EXAMPLES PANEL (Prompt Examples) -->
                <div class="design-view" id="view-examples" style="display: none;">
                  <div class="examples-filters">
                    <div class="filter-row">
                      <span class="filter-label">SURFACE</span>
                      <span class="filter-chip active">All 70</span>
                      <span class="filter-chip">Web 60</span>
                      <span class="filter-chip">Image 6</span>
                      <span class="filter-chip">Video 3</span>
                      <span class="filter-chip">Audio 1</span>
                    </div>
                    <div class="filter-row">
                      <span class="filter-label">TYPE</span>
                      <span class="filter-chip active">All 70</span>
                      <span class="filter-chip">Prototypes - Desktop 32</span>
                      <span class="filter-chip">Prototypes - Mobile 3</span>
                      <span class="filter-chip">Slides 22</span>
                      <span class="filter-chip">Docs & templates 0</span>
                      <span class="filter-chip">Orbit 5</span>
                    </div>
                    <div class="filter-row">
                      <span class="filter-label">SCENARIO</span>
                      <span class="filter-chip active">All 70</span>
                      <span class="filter-chip">Engineering 12</span>
                      <span class="filter-chip">Product 4</span>
                      <span class="filter-chip">Design 7</span>
                      <span class="filter-chip">Marketing 21</span>
                      <span class="filter-chip">Sales 1</span>
                      <span class="filter-chip">Finance 3</span>
                      <span class="filter-chip">HR 2</span>
                      <span class="filter-chip">Operations 5</span>
                      <span class="filter-chip">Education 1</span>
                      <span class="filter-chip">Personal 5</span>
                      <span class="filter-chip">General 1</span>
                    </div>
                    <div class="filter-row" style="margin-left: 50px;">
                      <span class="filter-chip">Creator 1</span>
                      <span class="filter-chip">Orbit 5</span>
                      <span class="filter-chip">Planning 1</span>
                      <span class="filter-chip">Video 1</span>
                    </div>
                  </div>

                  <div class="example-content-split">
                    <!-- Left example visual card -->
                    <div class="example-visual-side">
                      <div class="vintage-editorial-mock">
                        <div class="editorial-header">
                          <span>OD / 2026 · VOL. 01 / ISSUE Nº 28</span>
                          <span>● LIVE · V0.3.0</span>
                          <span>EN DE 中文 日本語</span>
                        </div>
                        <h3 class="editorial-logo">Open Design</h3>
                        <p class="editorial-tagline">Designing intelligence with skills, taste, and...</p>
                        <div class="editorial-body-placeholder">
                          <span></span><span></span><span></span>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Right example copy details -->
                    <div class="example-details-side">
                      <div class="example-card-head">
                        <h4 class="example-title">open-design-landing</h4>
                        <div class="example-badges">
                          <span class="badge-tag">DESKTOP PROTOTYPE</span>
                          <span class="badge-tag accent">MARKETING</span>
                        </div>
                      </div>
                      <p class="example-description">
                        "Produce a world-class single-page editorial landing site in the Atelier Zero visual language (Monocle / Apartamento / Études editorial collage) — the same aesthetic Open Design uses for its own marketing surface."
                      </p>
                      <div class="example-actions">
                        <button type="button" class="example-btn btn-use-prompt" id="btn-use-example-prompt">{l.useThisPrompt}</button>
                        <span class="example-btn btn-secondary" style="opacity:0.6; cursor:not-allowed;">{l.openPreview}</span>
                        <span class="example-btn btn-secondary" style="opacity:0.6; cursor:not-allowed;">{l.share}</span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- VIEW C: DESIGN SYSTEMS PANEL -->
                <div class="design-view" id="view-design-systems" style="display: none;">
                  <div class="design-systems-list">
                    <div class="ds-card active">
                      <div class="ds-meta">
                        <h4 class="ds-name">Neutral Modern</h4>
                        <span class="ds-badge">Default</span>
                      </div>
                      <div class="ds-palette">
                        <span class="color-block" style="background: #ffffff; border: 1px solid var(--color-border);"></span>
                        <span class="color-block" style="background: #f4f4f5;"></span>
                        <span class="color-block" style="background: #18181b;"></span>
                        <span class="color-block" style="background: #f97316;"></span>
                      </div>
                    </div>

                    <div class="ds-card">
                      <div class="ds-meta">
                        <h4 class="ds-name">Terminal Dark</h4>
                        <span class="ds-badge">System</span>
                      </div>
                      <div class="ds-palette">
                        <span class="color-block" style="background: #09090b;"></span>
                        <span class="color-block" style="background: #22c55e;"></span>
                        <span class="color-block" style="background: #27272a;"></span>
                        <span class="color-block" style="background: #3f3f46;"></span>
                      </div>
                    </div>

                    <div class="ds-card">
                      <div class="ds-meta">
                        <h4 class="ds-name">Glassmorphism</h4>
                        <span class="ds-badge">Premium</span>
                      </div>
                      <div class="ds-palette">
                        <span class="color-block" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"></span>
                        <span class="color-block" style="background: #06b6d4;"></span>
                        <span class="color-block" style="background: #3b82f6;"></span>
                        <span class="color-block" style="background: #1e1b4b;"></span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- VIEW F: CONNECTORS PANEL -->
                <div class="design-view" id="view-connectors" style="display: none;">
                  <div class="design-systems-list">
                    <div class="ds-card">
                      <div class="ds-meta">
                        <h4 class="ds-name">Figma Connector</h4>
                        <span class="ds-badge">Official Plugin</span>
                      </div>
                      <span style="font-size: 10px; color: var(--color-text-muted);">Sync layouts & component assets</span>
                    </div>
                    <div class="ds-card">
                      <div class="ds-meta">
                        <h4 class="ds-name">Github Assets</h4>
                        <span class="ds-badge" style="color: #22c55e;">Active Tunnel</span>
                      </div>
                      <span style="font-size: 10px; color: var(--color-text-muted);">Auto-push design system changes to git</span>
                    </div>
                  </div>
                </div>

                <!-- VIEW D: IMAGE TEMPLATES PANEL -->
                <div class="design-view" id="view-image-templates" style="display: none;">
                  <div class="templates-grid">
                    <!-- Template Card 1 -->
                    <div class="template-card">
                      <div class="template-media-placeholder img-staircase">
                        <div class="mock-image-stairs">
                          <span class="text-stairs">3D Stone Staircase</span>
                          <span class="evolution-label">Evolution Timeline</span>
                        </div>
                        <span class="gpt-badge">GPT Image 2</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">3D Stone Staircase Evolution Infographic</h5>
                        <p class="template-desc">Transforms a flat evolutionary timeline into a realistic 3D stone staircase infographic with detailed organism renders and structured si...</p>
                        <div class="template-tags">
                          <span class="t-tag">INFOGRAPHIC</span>
                          <span class="t-tag">3d-render</span>
                        </div>
                        <span class="template-source">Source: 知识描图解 · awesome-gpt-image-2</span>
                      </div>
                    </div>

                    <!-- Template Card 2 -->
                    <div class="template-card">
                      <div class="template-media-placeholder img-anime">
                        <div class="mock-image-anime">
                          <span class="text-anime">Anime Martial Arts</span>
                          <span class="action-label">Dojo Clash</span>
                        </div>
                        <span class="gpt-badge">GPT Image 2</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">Anime Martial Arts Battle Illustration</h5>
                        <p class="template-desc">Generates a dynamic, high-impact anime illustration of two female characters fighting in a traditional dojo with elemental energy...</p>
                        <div class="template-tags">
                          <span class="t-tag">ANIME / MANGA</span>
                          <span class="t-tag">anime</span>
                          <span class="t-tag">action</span>
                        </div>
                        <span class="template-source">Source: たねもみ 2.0 / Tanemomi Ver2.0 · awesome-gpt-image-2</span>
                      </div>
                    </div>

                    <!-- Template Card 3 -->
                    <div class="template-card">
                      <div class="template-media-placeholder img-stream">
                        <div class="mock-image-stream">
                          <span class="text-stream">E-commerce Live UI</span>
                          <span class="ui-label">Overlay & Chat</span>
                        </div>
                        <span class="gpt-badge">GPT Image 2</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">E-commerce Live Stream UI Mockup</h5>
                        <p class="template-desc">Generates a realistic social media live stream interface overlaying a portrait, featuring customizable chat messages, gift popups,...</p>
                        <div class="template-tags">
                          <span class="t-tag">APP / WEB DESIGN</span>
                          <span class="t-tag">portrait</span>
                          <span class="t-tag">fantasy</span>
                          <span class="t-tag">product</span>
                        </div>
                        <span class="template-source">Source: 神经病不想好转 · awesome-gpt-image-2</span>
                      </div>
                    </div>

                    <!-- Template Card 4 -->
                    <div class="template-card">
                      <div class="template-media-placeholder img-game">
                        <div class="mock-image-game">
                          <span class="text-game">Anime Fighting HUD</span>
                          <span class="hud-label">45s · HUD UI</span>
                        </div>
                        <span class="gpt-badge">Open Design</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">Game Screenshot - Anime Fighting Game: Captain Ryuuga vs Kaze Renshin</h5>
                        <p class="template-desc">An in-game fighting game key visual / combat screenshot in the style of Street Fighter 6 or Tekken 8 intro art. Two anime-style male...</p>
                        <div class="template-tags">
                          <span class="t-tag">GAME UI</span>
                          <span class="t-tag">game-ui</span>
                          <span class="t-tag">fighting-game</span>
                          <span class="t-tag">anime</span>
                        </div>
                        <span class="template-source">Source: open-design contributors · open-design</span>
                      </div>
                    </div>

                    <!-- Template Card 5 -->
                    <div class="template-card">
                      <div class="template-media-placeholder img-ancient">
                        <div class="mock-image-ancient">
                          <span class="text-game">Chinese Warrior</span>
                          <span class="hud-label">Stormy Sky</span>
                        </div>
                        <span class="gpt-badge">Open Design</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">Ancient Chinese Warrior Showdown</h5>
                        <p class="template-desc">Cinematic action shot of a warrior on horseback confronting an army under stormy skies.</p>
                        <div class="template-tags">
                          <span class="t-tag">GAME ART</span>
                          <span class="t-tag">cinematic</span>
                          <span class="t-tag">fantasy</span>
                        </div>
                        <span class="template-source">Source: open-design contributors</span>
                      </div>
                    </div>

                    <!-- Template Card 6 -->
                    <div class="template-card">
                      <div class="template-media-placeholder img-sunset">
                        <div class="mock-image-sunset">
                          <span class="text-game">Sunset Archer</span>
                          <span class="hud-label">Silhouette</span>
                        </div>
                        <span class="gpt-badge">Open Design</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">Sunset Archer Concept</h5>
                        <p class="template-desc">An archer standing on a clifftop aiming at the sunset, silhouette lighting with high contrast.</p>
                        <div class="template-tags">
                          <span class="t-tag">CONCEPT ART</span>
                          <span class="t-tag">sunset</span>
                          <span class="t-tag">silhouette</span>
                        </div>
                        <span class="template-source">Source: open-design contributors</span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- VIEW E: VIDEO TEMPLATES PANEL -->
                <div class="design-view" id="view-video-templates" style="display: none;">
                  <div class="templates-grid">
                    <!-- Video Card 1 -->
                    <div class="template-card">
                      <div class="template-media-placeholder video-presenter">
                        <div class="video-preview-mesh">
                          <span class="play-btn-icon">▶</span>
                          <span>AI Avatar Presenter</span>
                        </div>
                        <span class="gpt-badge">Open Design</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">AI Presenter - Product Pitch</h5>
                        <p class="template-desc">Photorealistic AI avatar speaking about product features with automated slides.</p>
                        <div class="template-tags">
                          <span class="t-tag">VIDEO PRESENTATION</span>
                          <span class="t-tag">ai-avatar</span>
                        </div>
                      </div>
                    </div>

                    <!-- Video Card 2 -->
                    <div class="template-card">
                      <div class="template-media-placeholder video-promo">
                        <div class="video-preview-mesh">
                          <span class="play-btn-icon">▶</span>
                          <span>B-roll Promo Loop</span>
                        </div>
                        <span class="gpt-badge">Open Design</span>
                      </div>
                      <div class="template-info">
                        <h5 class="template-title">Sleek App Promo Loop</h5>
                        <p class="template-desc">Cinematic transitions displaying screenshots and code editors with subtle glows.</p>
                        <div class="template-tags">
                          <span class="t-tag">PROMOTIONAL</span>
                          <span class="t-tag">motion-graphics</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

              </div>
            </main>

            <!-- 3. RIGHT SIDEBAR: PETS PANEL -->
            <aside class="design-right-sidebar" id="design-pets-sidebar">
              <div class="pets-header">
                <span class="pets-title">⚡ PETS</span>
                <div class="pets-window-actions">
                  <span style="cursor:default;">‹</span>
                  <span style="cursor:default;">›</span>
                  <span class="close-pets-btn" id="close-pets-btn">×</span>
                </div>
              </div>
              <p class="pets-desc">Pick a companion to float over your workspace.</p>
              
              <button type="button" class="btn-tuck-away" id="btn-tuck-away">
                <span class="tuck-icon">💤</span>
                <span class="tuck-text">Tuck away</span>
              </button>
              
              <div class="pets-list">
                <div class="pet-item active" id="pet-item-buddy">
                  <span class="pet-icon">🦄</span>
                  <div class="pet-info">
