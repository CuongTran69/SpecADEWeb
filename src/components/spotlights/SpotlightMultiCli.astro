---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'
import Spotlight from '~/components/Spotlight.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const tabs = [
  { id: 'claude', label: 'Claude', icon: '◆', cls: 'tab-claude' },
  { id: 'auggie', label: 'Auggie', icon: '●', cls: 'tab-auggie' },
  { id: 'codex', label: 'Codex', icon: '▲', cls: 'tab-codex', active: true },
  { id: 'custom', label: 'Custom ACP', icon: '★', cls: 'tab-custom' },
]
---

<Spotlight id="multi-cli" hook={strings.spotlight.multiCli.hook} body={strings.spotlight.multiCli.body} tone="default">
  <div slot="visual" class="multicli-mock">
    <div class="multicli-tabs" role="tablist" data-multicli-tabs>
      {tabs.map((tab) => (
        <button
          type="button"
          class={`multicli-tab ${tab.cls}${tab.active ? ' multicli-tab--active' : ''}`}
          role="tab"
          aria-selected={tab.active ? 'true' : 'false'}
          tabindex={tab.active ? 0 : -1}
          data-cli={tab.id}
          data-testid={`multicli-tab-${tab.id}`}
        >
          <span class="tab-icon">{tab.icon}</span>
          <span class="tab-label">{tab.label}</span>
          <span class="tab-active-dot" aria-hidden="true" style={tab.active ? 'display: inline-block;' : 'display: none;'}></span>
        </button>
      ))}
    </div>
    <div class="multicli-body">
      <!-- Claude Panel -->
      <div class="multicli-panel" data-cli-panel="claude" hidden>
        <div class="multicli-bubble">
          <span class="bubble-icon cl-claude">◆</span>
          <span class="bubble-text">
            <strong>Claude Code v0.5.1</strong><br/>
            Reading your codebase...<br/>
            I'll add a login page with JWT auth. Starting now.<br/>
            <span class="cl-git-m">M  src/pages/Login.vue</span><br/>
            <span class="cl-git-a">A  src/stores/auth.ts</span><br/>
            <span class="cl-git-a">A  src/api/auth.rs</span><br/>
            <span class="cl-success">✓ Done · 3 files · 0 conflicts · tests passing</span>
          </span>
        </div>
      </div>
      <!-- Auggie Panel -->
      <div class="multicli-panel" data-cli-panel="auggie" hidden>
        <div class="multicli-bubble">
          <span class="bubble-icon cl-auggie">●</span>
          <span class="bubble-text">
            <strong>Auggie Agent v1.2</strong><br/>
            Scanning workspace for security vulnerabilities...<br/>
            No critical vulnerabilities found.<br/>
            Analyzing code quality of 14 components.<br/>
            <span class="cl-success">✓ Analysis complete: 100% test coverage target met.</span>
          </span>
        </div>
      </div>
      <!-- Codex Panel (Active by default) -->
      <div class="multicli-panel" data-cli-panel="codex">
        <div class="multicli-bubble">
          <span class="bubble-icon cl-codex">▲</span>
          <span class="bubble-text">
            <strong>Codex Code Gen</strong><br/>
            Autocompleting function signature...<br/>
            Adding type definitions for WebSocket events.<br/>
            <span class="cl-success">✓ Successfully generated 4 helper classes.</span>
          </span>
        </div>
      </div>
      <!-- Custom ACP Panel -->
      <div class="multicli-panel" data-cli-panel="custom" hidden>
        <div class="multicli-bubble">
          <span class="bubble-icon cl-custom">★</span>
          <span class="bubble-text">
            <strong>Custom ACP Protocol Agent</strong><br/>
            Connecting to local language server (LSP)...<br/>
            Index build complete.<br/>
            <span class="cl-success">Ready to receive ACP commands.</span>
          </span>
        </div>
      </div>

      <div class="multicli-cursor" aria-hidden="true">
        <span class="cursor-bar"></span>
      </div>
    </div>
  </div>
  <a slot="extra" href={pathFor(lang, '/features#multi-agent')} class="btn btn-secondary" style="margin-top: 8px;">
    {strings.spotlight.multiCli.viewDetailBtn}
  </a>
</Spotlight>

<script>
  if (!document.documentElement.dataset.multiCliTabsInit) {
    document.documentElement.dataset.multiCliTabsInit = '1'

    const tabsContainer = document.querySelector('[data-multicli-tabs]')
    if (tabsContainer) {
      const tabs = tabsContainer.querySelectorAll<HTMLButtonElement>('[role="tab"]')
      const panels = document.querySelectorAll<HTMLElement>('[data-cli-panel]')

      function activateTab(btn: HTMLButtonElement) {
        const targetId = btn.dataset.cli
        if (!targetId) return

        tabs.forEach((tab) => {
          const isActive = tab === btn
          tab.setAttribute('aria-selected', isActive ? 'true' : 'false')
          tab.setAttribute('tabindex', isActive ? '0' : '-1')
          tab.classList.toggle('multicli-tab--active', isActive)

          const dot = tab.querySelector('.tab-active-dot') as HTMLElement
          if (dot) dot.style.display = isActive ? 'inline-block' : 'none'
        })

        panels.forEach((panel) => {
          panel.hidden = panel.dataset.cliPanel !== targetId
        })
      }

      tabsContainer.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest<HTMLButtonElement>('[role="tab"]')
        if (btn) activateTab(btn)
      })

      tabsContainer.addEventListener('keydown', (e) => {
        const ke = e as KeyboardEvent
        if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(ke.key)) return
        const btns = Array.from(tabs)
        const idx = btns.indexOf(document.activeElement as HTMLButtonElement)
        let next = idx

        if (ke.key === 'ArrowRight') next = (idx + 1) % btns.length
        else if (ke.key === 'ArrowLeft') next = (idx - 1 + btns.length) % btns.length
        else if (ke.key === 'Home') next = 0
        else if (ke.key === 'End') next = btns.length - 1

        if (next !== idx) {
          ke.preventDefault()
          const target = btns[next]
          if (target) {
            activateTab(target)
            target.focus()
          }
        }
      })
    }
  }
</script>

<style>
  .multicli-mock {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .multicli-tabs {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-raised);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .multicli-tabs::-webkit-scrollbar { display: none; }

  .multicli-tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    color: var(--color-text-secondary);
    font-size: 12px;
    white-space: nowrap;
    border-right: 1px solid var(--color-border);
    border-top: none;
    border-left: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    position: relative;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background 150ms var(--ease-out-soft), color 150ms var(--ease-out-soft);
  }

  .multicli-tab:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .multicli-tab--active {
    background: var(--color-surface);
    color: var(--color-text);
    border-bottom: 2px solid var(--color-accent);
  }

  .multicli-tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .tab-claude .tab-icon { color: var(--color-claude); }
  .tab-auggie .tab-icon { color: var(--color-auggie, #f59e0b); }
  .tab-codex .tab-icon { color: var(--color-accent); }
  .tab-custom .tab-icon { color: var(--color-claude); }

  .tab-active-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: dot-pulse 2s ease-in-out infinite;
    display: inline-block;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tab-active-dot { animation: none; }
  }

  .multicli-body {
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 180px;
    background: color-mix(in srgb, var(--color-bg) 15%, var(--color-surface));
  }

  .multicli-panel {
    display: flex;
    flex-direction: column;
    width: 100%;
    animation: panel-fade 250ms var(--ease-out-soft);
  }

  @keyframes panel-fade {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .multicli-bubble {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 14px 16px;
  }

  .bubble-icon {
    font-size: 12px;
    margin-top: 2px;
    flex-shrink: 0;
    font-weight: bold;
  }

  .cl-claude { color: var(--color-claude); }
  .cl-auggie { color: var(--color-auggie, #fbbf24); }
  .cl-codex { color: var(--color-accent); }
  .cl-custom { color: var(--color-claude); }
  .cl-git-m { color: var(--color-git-modified); }
  .cl-git-a { color: var(--color-git-added); }
  .cl-success { color: var(--color-success); font-weight: 600; }

  .bubble-text {
    color: var(--color-text-secondary);
    font-size: 12.5px;
    line-height: 1.65;
  }

  .multicli-cursor {
    display: flex;
    align-items: center;
    padding-left: 4px;
  }

  .cursor-bar {
    display: inline-block;
    width: 2px;
    height: 14px;
    background: var(--color-accent);
    animation: cursor-blink 1.1s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-bar { animation: none; }
  }
</style>
