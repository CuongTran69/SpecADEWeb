---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import Spotlight from '~/components/Spotlight.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const tabs = [
  { id: 'claude', label: 'Claude', icon: '◆', cls: 'tab-claude' },
  { id: 'auggie', label: 'Auggie', icon: '●', cls: 'tab-auggie' },
  { id: 'codex', label: 'Codex', icon: '▲', cls: 'tab-codex', active: true },
  { id: 'custom', label: 'Custom ACP', icon: '★', cls: 'tab-custom' },
]
---

<Spotlight id="multi-cli" hook={strings.spotlight.multiCli.hook} body={strings.spotlight.multiCli.body} tone="default">
  <div slot="visual" class="multicli-mock" aria-hidden="true">
    <div class="multicli-tabs" role="tablist">
      {tabs.map((tab) => (
        <div class={`multicli-tab ${tab.cls}${tab.active ? ' multicli-tab--active' : ''}`} role="tab" aria-selected={tab.active ? 'true' : 'false'}>
          <span class="tab-icon">{tab.icon}</span>
          <span class="tab-label">{tab.label}</span>
          {tab.active && <span class="tab-active-dot" aria-hidden="true"></span>}
        </div>
      ))}
    </div>
    <div class="multicli-body">
      <div class="multicli-bubble">
        <span class="bubble-icon">◆</span>
        <span class="bubble-text">Reading context from 3 agents in parallel...</span>
      </div>
      <div class="multicli-cursor" aria-hidden="true">
        <span class="cursor-bar"></span>
      </div>
    </div>
  </div>
</Spotlight>

<style>
  .multicli-mock {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .multicli-tabs {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-raised);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .multicli-tabs::-webkit-scrollbar { display: none; }

  .multicli-tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    color: var(--color-text-muted);
    font-size: 12px;
    white-space: nowrap;
    border-right: 1px solid var(--color-border);
    position: relative;
    cursor: default;
  }

  .multicli-tab--active {
    background: var(--color-surface);
    color: var(--color-text);
    border-bottom: 2px solid var(--color-accent);
  }

  .tab-claude .tab-icon { color: var(--color-claude); }
  .tab-auggie .tab-icon { color: var(--color-auggie, #f59e0b); }
  .tab-codex .tab-icon { color: var(--color-accent); }
  .tab-custom .tab-icon { color: var(--color-claude); }

  .tab-active-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tab-active-dot { animation: none; }
  }

  .multicli-body {
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 80px;
  }

  .multicli-bubble {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 10px 12px;
  }

  .bubble-icon {
    color: var(--color-accent);
    font-size: 11px;
    margin-top: 1px;
    flex-shrink: 0;
  }

  .bubble-text {
    color: var(--color-text-secondary);
    font-size: 12px;
    line-height: 1.5;
  }

  .multicli-cursor {
    display: flex;
    align-items: center;
    padding-left: 4px;
  }

  .cursor-bar {
    display: inline-block;
    width: 2px;
    height: 14px;
    background: var(--color-accent);
    animation: cursor-blink 1.1s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-bar { animation: none; }
  }
</style>
