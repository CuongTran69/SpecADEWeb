---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'
import Spotlight from '~/components/Spotlight.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
const s = strings.spotlight.port
---

<Spotlight id="port" hook={s.hook} body={s.body} tone="accent" flip>
  <div slot="visual" class="port-mock" aria-hidden="true">
    <!-- Title / Command Bar -->
    <div class="port-bar">
      <div class="port-dots">
        <span class="port-dot dot-red"></span>
        <span class="port-dot dot-amber"></span>
        <span class="port-dot dot-green"></span>
      </div>
      <span class="port-title">ade tunnel --expose 4124</span>
    </div>

    <!-- Terminal output showing tunnel setup -->
    <div class="port-terminal-output">
      <div class="term-line animate-line-1">
        <span class="term-prompt">$</span> ade tunnel --expose 4124 --access-key
      </div>
      <div class="term-line dim animate-line-2">
        ⚡ Forwarding ADE workspace on port 4124...
      </div>
      <div class="term-line dim animate-line-3">
        🌐 Establishing Cloudflare Tunnel...
      </div>
      <div class="term-line success animate-line-4">
        ✓ Tunnel active: <span class="text-cyan">https://ade.spec-ade.dev</span>
      </div>
      <div class="term-line dim animate-line-5">
        🔒 Access Key: <span class="text-amber">ade_key_6868_cf</span>
      </div>
      <div class="term-line success animate-line-6">
        ✓ Spec ADE is now accessible from any browser!
      </div>
    </div>
  </div>

  <a slot="extra" href={pathFor(lang, '/features#port-forwarding')} class="btn btn-secondary" style="margin-top: 8px;">
    {s.viewDetailBtn}
  </a>
</Spotlight>

<style>
  .port-mock {
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 12.5px;
    box-sizing: border-box;
    transition: border-color 300ms var(--ease-out-soft);
  }

  .port-mock:hover {
    border-color: var(--color-accent);
  }

  .port-bar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: var(--color-raised);
    border-bottom: 1px solid var(--color-border-strong);
    user-select: none;
  }

  .port-dots {
    display: flex;
    gap: 6px;
  }

  .port-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-amber { background: #febc2e; }
  .dot-green { background: #28c840; }

  .port-title {
    margin-left: 16px;
    font-size: 11.5px;
    color: var(--color-text-secondary);
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  .port-terminal-output {
    padding: 16px;
    background: color-mix(in srgb, var(--color-bg) 20%, var(--color-surface));
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .term-line {
    color: #a5b4fc;
    font-size: 11.5px;
    line-height: 1.6;
    opacity: 0;
    transform: translateY(4px);
    animation: termReveal 300ms var(--ease-out-soft) forwards;
  }

  .term-line.dim { color: var(--color-text-muted); }
  .term-line.success { color: var(--color-success); font-weight: 600; }

  .term-prompt {
    color: var(--color-accent);
    font-weight: 700;
    margin-right: 4px;
  }

  .text-cyan { color: var(--color-accent); font-weight: 600; }
  .text-amber { color: var(--color-warning); font-weight: 600; }

  .animate-line-1 { animation-delay: 0ms; }
  .animate-line-2 { animation-delay: 400ms; }
  .animate-line-3 { animation-delay: 800ms; }
  .animate-line-4 { animation-delay: 1200ms; }
  .animate-line-5 { animation-delay: 1600ms; }
  .animate-line-6 { animation-delay: 2000ms; }

  @keyframes termReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .term-line { animation: none; opacity: 1; transform: none; }
  }
</style>
