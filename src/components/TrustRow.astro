---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
const stats = [
  { id: 'ai', ...strings.trust.ai, icon: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/></svg>` },
  { id: 'db', ...strings.trust.db, icon: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>` },
  { id: 'deploy', ...strings.trust.deploy, icon: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>` },
  { id: 'privacy', ...strings.trust.privacy, icon: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>` },
]
---

<section class="trust-row" data-testid="trust-row" aria-label={lang === 'vi' ? 'Tin cậy bằng số' : 'Trust signals'}>
  <div class="container-wide">
    <div class="trust-grid">
      {stats.map((stat, i) => (
        <article class="trust-card reveal" data-testid={`trust-card-${stat.id}`} style={`animation-delay:${i * 60}ms`}>
          <div class="trust-icon icon-badge" set:html={stat.icon}></div>
          <div class="trust-content">
            <span class="trust-value">{stat.value}</span>
            <span class="trust-label">{stat.label}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-row {
    padding-block: clamp(48px, 6vw, 72px);
    background: var(--color-bg);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (min-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  .trust-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 22px 24px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    transition: border-color 250ms var(--ease-out-soft), transform 250ms var(--ease-out-soft), box-shadow 250ms var(--ease-out-soft);
  }

  .trust-card:hover {
    border-color: color-mix(in oklab, var(--color-accent) 40%, transparent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px color-mix(in oklab, var(--color-accent) 6%, transparent);
  }

  .trust-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .trust-value {
    font-family: var(--font-mono);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .trust-label {
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }
</style>
