---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import CopyBlock from '~/components/CopyBlock.astro'
import Icon from '~/components/Icon.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
---

<section id="get-started" class="get-started">
  <div class="container-wide">
    <header class="section-head reveal">
      <span class="chip">{strings.getStarted.chip}</span>
      <h2 class="section-title">{strings.getStarted.title}</h2>
      <p class="section-subtitle">{strings.getStarted.subtitle}</p>
    </header>

    <div class="get-started-layout">
      <!-- Left: install card -->
      <div class="install-side">
        <div class="activation-note reveal" data-testid="activation-note">
          <div class="activation-icon" aria-hidden="true">
            <Icon name="lock" size={18} />
          </div>
          {(() => {
            const note = strings.getStarted.comingSoonNote
            const parts = note.split('`ADE-xxx`')
            return (
              <p class="activation-text">
                {parts[0]}
                {parts.length > 1 && <code>ADE-xxx</code>}
                {parts.slice(1).join('`ADE-xxx`')}
              </p>
            )
          })()}
        </div>

        <div class="install-card surface reveal">
          <div class="npm-coming-soon-note" data-testid="npm-coming-soon-note">
            <p class="npm-coming-soon-text">
              {lang === 'vi' ? (
                <>
                  Đã chính thức phát hành <a href="https://www.npmjs.com/package/@spec-ade/cli" target="_blank" rel="noopener noreferrer" class="npm-link">@spec-ade/cli</a> trên npm. Chạy lệnh bên dưới để cài đặt và sử dụng ngay lập tức.
                </>
              ) : (
                <>
                  <a href="https://www.npmjs.com/package/@spec-ade/cli" target="_blank" rel="noopener noreferrer" class="npm-link">@spec-ade/cli</a> is officially published on npm. Run the command below to install and run the workspace instantly.
                </>
              )}
            </p>
          </div>

          <div class="install-methods">
            <!-- Method 1: Local installation -->
            <div class="method-block">
              <span class="method-label">
                {lang === 'vi' ? 'Cài đặt và chạy (macOS, Windows, Linux)' : 'Install & Run (macOS, Windows, Linux)'}
              </span>
              <CopyBlock code="npx -y @spec-ade/cli@latest" />
            </div>

            <!-- Method 2: VPS / Server -->
            <div class="method-block">
              <span class="method-label">
                {lang === 'vi' ? 'Cài đặt trên VPS / Cloud Server' : 'Install on VPS / Cloud Server'}
              </span>
              <CopyBlock code="npx -y @spec-ade/cli@latest --host 0.0.0.0 --port 3100" />
              <p class="vps-note">{strings.getStarted.vpsNote}</p>
            </div>
          </div>

          <p class="note">{strings.getStarted.note}</p>
        </div>

        <div class="auto-open-callout" data-testid="auto-open-callout">
          <Icon name="external-link" size={15} />
          <span>{strings.getStarted.autoOpenNote}</span>
        </div>
      </div>

      <!-- Right: Node.js prereq -->
      <div class="prereq-side reveal">
        <details class="nodejs-details" data-testid="nodejs-details">
          <summary class="nodejs-summary">
            <span>{strings.getStarted.dontHaveNpx}</span>
            <Icon name="chevron-down" size={14} class="details-chevron" />
          </summary>
          <div class="nodejs-body">
            <p class="nodejs-required">{strings.getStarted.nodejsRequired}</p>
            <div class="nodejs-platforms">
              <div class="nodejs-platform">
                <h4 class="platform-name">{strings.getStarted.nodeMac}</h4>
                <CopyBlock code="brew install node@22" />
                <p class="platform-alt">or visit <a href="https://nodejs.org/" target="_blank" rel="noopener noreferrer">nodejs.org</a></p>
              </div>
              <div class="nodejs-platform">
                <h4 class="platform-name">{strings.getStarted.nodeLinux}</h4>
                <CopyBlock code={`curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash -\nsudo apt-get install -y nodejs`} />
                <p class="platform-alt">Ubuntu/Debian. For RHEL/Fedora see <a href="https://github.com/nodesource/distributions#rhel-versions" target="_blank" rel="noopener noreferrer">NodeSource RHEL guide</a>.</p>
              </div>
              <div class="nodejs-platform">
                <h4 class="platform-name">{strings.getStarted.nodeWin}</h4>
                <CopyBlock code="winget install OpenJS.NodeJS" />
                <p class="platform-alt">or download installer at <a href="https://nodejs.org/" target="_blank" rel="noopener noreferrer">nodejs.org</a></p>
              </div>
            </div>
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<style>
  .get-started {
    padding-block: clamp(72px, 9vw, 112px);
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 48px;
    max-width: 44rem;
  }

  .get-started-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .get-started-layout {
      grid-template-columns: 1.4fr 1fr;
      gap: 40px;
    }
  }

  .install-side {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Activation note */
  .activation-note {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 20px;
    background: var(--color-accent-soft);
    border: 1px solid color-mix(in oklab, var(--color-accent) 25%, transparent);
    border-radius: var(--radius-xl);
  }

  .activation-icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .activation-text {
    margin: 0;
    color: var(--color-text);
    font-size: 13.5px;
    line-height: 1.65;
  }

  .activation-text :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 1px 6px;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xs);
    color: var(--color-accent);
  }

  /* Install card */
  .install-card {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-radius: var(--radius-xl);
  }

  @media (min-width: 768px) {
    .install-card { padding: 28px; }
  }

  /* npm coming-soon notice */
  .npm-coming-soon-note {
    padding: 12px 16px;
    background: color-mix(in oklab, var(--color-success) 8%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-success) 25%, transparent);
    border-radius: var(--radius-md);
  }

  .npm-coming-soon-text {
    margin: 0;
    font-size: 13px;
    color: var(--color-success);
    line-height: 1.55;
  }

  .npm-link {
    font-weight: 600;
    color: var(--color-success);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 150ms var(--ease-out-soft);
  }

  .npm-link:hover {
    opacity: 0.8;
  }

  .install-methods {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .method-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .method-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .vps-note {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 0;
    padding: 10px 14px;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    line-height: 1.5;
  }

  .note {
    font-size: 12.5px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Auto-open callout */
  .auto-open-callout {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text-secondary);
    font-size: 13px;
  }

  .auto-open-callout svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  /* Prereq side */
  .prereq-side {
    position: sticky;
    top: 80px;
  }

  /* Node.js details */
  .nodejs-details {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg);
    overflow: hidden;
    transition: background 200ms var(--ease-out-soft);
  }

  .nodejs-details[open] {
    background: var(--color-surface);
  }

  .nodejs-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--color-text-secondary);
    transition: color 150ms var(--ease-out-soft);
  }

  .nodejs-summary::-webkit-details-marker { display: none; }
  .nodejs-summary:hover { color: var(--color-text); }

  .nodejs-summary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .details-chevron {
    flex-shrink: 0;
    transition: transform 250ms var(--ease-out-soft);
  }

  .nodejs-details[open] .details-chevron {
    transform: rotate(180deg);
  }

  .nodejs-body {
    padding: 0 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .nodejs-required {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0;
  }

  .nodejs-platforms {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .nodejs-platform {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .platform-name {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .platform-alt {
    font-size: 12px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .platform-alt a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .platform-alt a:hover { text-decoration: underline; }
</style>
