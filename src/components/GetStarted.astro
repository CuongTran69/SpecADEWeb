---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import CopyBlock from '~/components/CopyBlock.astro'
import Icon from '~/components/Icon.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const tabs = [
  { id: 'mac', label: strings.getStarted.macTab, recommended: true },
  { id: 'linux', label: strings.getStarted.linuxTab, recommended: false },
  { id: 'win', label: strings.getStarted.winTab, recommended: false },
  { id: 'source', label: strings.getStarted.sourceTab, recommended: false },
]

const blocks: Record<string, { install: string; service?: string; vpsNote?: boolean }> = {
  mac: {
    install: `npx -y @spec-ade/cli@latest`,
    service: `npx -y @spec-ade/cli@latest --install-service`,
  },
  linux: {
    install: `npx -y @spec-ade/cli@latest`,
    service: `npx -y @spec-ade/cli@latest --install-service`,
  },
  win: {
    install: `npx -y @spec-ade/cli@latest`,
    service: `npx -y @spec-ade/cli@latest --install-service`,
  },
  source: {
    install: `npx -y @spec-ade/cli@latest --host 0.0.0.0 --port 3100`,
    service: `npx -y @spec-ade/cli@latest --install-service --host 0.0.0.0`,
    vpsNote: true,
  },
}
---

<section id="get-started" class="get-started">
  <div class="container-wide">
    <header class="section-head">
      <span class="chip">{strings.getStarted.chip}</span>
      <h2 class="section-title">{strings.getStarted.title}</h2>
      <p class="section-subtitle">{strings.getStarted.subtitle}</p>
    </header>

    <div class="activation-note" data-testid="activation-note">
      <div class="activation-icon" aria-hidden="true">
        <Icon name="lock" size={20} />
      </div>
      <p class="activation-text" set:html={strings.getStarted.comingSoonNote.replaceAll('`ADE-xxx`', '<code>ADE-xxx</code>')}></p>
    </div>

    <!-- Full install card with tabs -->
    <div class="install-card surface">
      <!-- npm coming-soon notice -->
      <div class="npm-coming-soon-note" data-testid="npm-coming-soon-note">
        <p class="npm-coming-soon-text">{strings.getStarted.npmComingSoon}</p>
      </div>

      <!-- Tab strip -->
      <div class="tab-strip" role="tablist" aria-label={lang === 'vi' ? 'Hướng dẫn cài đặt' : 'Install instructions'} data-install-tabs>
        {tabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            id={`itab-${tab.id}`}
            aria-controls={`ipanel-${tab.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            class={`tab${i === 0 ? ' active' : ''}`}
            data-tab={tab.id}
            data-testid={`install-tab-${tab.id}`}
          >
            {tab.label}
            {tab.recommended && (
              <span class="recommended-badge">{strings.getStarted.recommendedBadge}</span>
            )}
          </button>
        ))}
      </div>

      <!-- Panels -->
      {tabs.map((tab, i) => {
        const block = blocks[tab.id]
        return (
          <div
            id={`ipanel-${tab.id}`}
            role="tabpanel"
            aria-labelledby={`itab-${tab.id}`}
            hidden={i !== 0}
            class="panel"
            data-panel={tab.id}
          >
            <div class="block-row">
              <span class="block-label">{strings.getStarted.installLabel}</span>
              <CopyBlock code={block?.install ?? ''} />
            </div>

            {block?.vpsNote && (
              <p class="vps-note">{strings.getStarted.vpsNote}</p>
            )}

            {block?.service && (
              <div class="block-row">
                <span class="block-label">{strings.getStarted.serviceLabel}</span>
                <CopyBlock code={block.service} />
              </div>
            )}
          </div>
        )
      })}

      <p class="note">{strings.getStarted.note}</p>
    </div>

    <!-- Auto-open callout -->
    <div class="auto-open-callout" data-testid="auto-open-callout">
      <Icon name="external-link" size={16} />
      <span>{strings.getStarted.autoOpenNote}</span>
    </div>

    <!-- Node.js prerequisite details -->
    <details class="nodejs-details" data-testid="nodejs-details">
      <summary class="nodejs-summary">
        <span>{strings.getStarted.dontHaveNpx}</span>
        <Icon name="chevron-down" size={14} class="details-chevron" />
      </summary>
      <div class="nodejs-body">
        <p class="nodejs-required">{strings.getStarted.nodejsRequired}</p>
        <div class="nodejs-platforms">
          <div class="nodejs-platform">
            <h4 class="platform-name" aria-label={strings.getStarted.nodeMac}>{strings.getStarted.nodeMac}</h4>
            <CopyBlock code="brew install node@22" />
            <p class="platform-alt">or visit <a href="https://nodejs.org/" target="_blank" rel="noopener noreferrer" aria-label="nodejs.org">nodejs.org</a></p>
          </div>
          <div class="nodejs-platform">
            <h4 class="platform-name" aria-label={strings.getStarted.nodeLinux}>{strings.getStarted.nodeLinux}</h4>
            <CopyBlock code={`curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash -\nsudo apt-get install -y nodejs`} />
            <p class="platform-alt">Ubuntu/Debian. For RHEL/Fedora see <a href="https://github.com/nodesource/distributions#rhel-versions" target="_blank" rel="noopener noreferrer" aria-label="NodeSource RHEL guide">NodeSource RHEL guide</a>.</p>
          </div>
          <div class="nodejs-platform">
            <h4 class="platform-name" aria-label={strings.getStarted.nodeWin}>{strings.getStarted.nodeWin}</h4>
            <CopyBlock code="winget install OpenJS.NodeJS" />
            <p class="platform-alt">or download installer at <a href="https://nodejs.org/" target="_blank" rel="noopener noreferrer" aria-label="nodejs.org">nodejs.org</a></p>
          </div>
        </div>
      </div>
    </details>
  </div>
</section>

<script>
  // Vanilla JS install tab switching — no Vue island needed
  if (!document.documentElement.dataset.installTabsInit) {
    document.documentElement.dataset.installTabsInit = '1'

    const installTabBar = document.querySelector('[data-install-tabs]')
    if (installTabBar) {
      const buttons = installTabBar.querySelectorAll<HTMLButtonElement>('[role="tab"]')

      function activateInstallTab(btn: HTMLButtonElement) {
        const tabId = btn.dataset.tab
        if (!tabId) return
        buttons.forEach((b) => {
          const isActive = b === btn
          b.setAttribute('aria-selected', isActive ? 'true' : 'false')
          b.setAttribute('tabindex', isActive ? '0' : '-1')
          b.classList.toggle('active', isActive)
        })
        document.querySelectorAll<HTMLElement>('[data-panel]').forEach((panel) => {
          panel.hidden = panel.dataset.panel !== tabId
        })
      }

      installTabBar.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest<HTMLButtonElement>('[role="tab"]')
        if (btn) activateInstallTab(btn)
      })

      installTabBar.addEventListener('keydown', (e) => {
        const ke = e as KeyboardEvent
        if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(ke.key)) return
        const btns = Array.from(buttons)
        const idx = btns.indexOf(document.activeElement as HTMLButtonElement)
        let next = idx
        if (ke.key === 'ArrowRight') next = (idx + 1) % btns.length
        else if (ke.key === 'ArrowLeft') next = (idx - 1 + btns.length) % btns.length
        else if (ke.key === 'Home') next = 0
        else if (ke.key === 'End') next = btns.length - 1
        if (next !== idx) {
          ke.preventDefault()
          const target = btns[next]
          if (target) { activateInstallTab(target); target.focus() }
        }
      })
    }
  }
</script>

<style>
  .get-started {
    padding-block: clamp(64px, 8vw, 96px);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
    max-width: 42rem;
  }

  /* Auto-open callout (full version) */
  .auto-open-callout {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    max-width: 52rem;
    color: var(--color-text-secondary);
    font-size: 13px;
  }

  .auto-open-callout svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  /* VPS note */
  .vps-note {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 0;
    padding: 10px 14px;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    line-height: 1.5;
  }

  /* Node.js details */
  .nodejs-details {
    max-width: 52rem;
    margin-top: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    overflow: hidden;
    transition: background 200ms var(--ease-out-soft);
  }

  .nodejs-details[open] {
    background: var(--color-surface);
  }

  .nodejs-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 18px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 150ms var(--ease-out-soft);
  }

  .nodejs-summary::-webkit-details-marker {
    display: none;
  }

  .nodejs-summary:hover {
    color: var(--color-text);
  }

  .nodejs-summary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .details-chevron {
    flex-shrink: 0;
    transition: transform 250ms var(--ease-out-soft);
  }

  .nodejs-details[open] .details-chevron {
    transform: rotate(180deg);
  }

  .nodejs-body {
    padding: 0 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .nodejs-required {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0;
  }

  .nodejs-platforms {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .nodejs-platforms {
      flex-direction: row;
      gap: 20px;
    }

    .nodejs-platform {
      flex: 1;
    }
  }

  .nodejs-platform {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .platform-name {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .platform-alt {
    font-size: 12px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .platform-alt a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .platform-alt a:hover {
    text-decoration: underline;
  }

  /* npm coming-soon notice */
  .npm-coming-soon-note {
    padding: 12px 16px;
    background: color-mix(in oklab, var(--color-warning) 10%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-warning) 30%, transparent);
    border-radius: var(--radius-md);
  }

  .npm-coming-soon-text {
    margin: 0;
    font-size: 13px;
    color: var(--color-warning);
    line-height: 1.55;
  }

  /* Activation note */
  .activation-note {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-top: 16px;
    padding: 16px 18px;
    background: var(--color-accent-soft);
    border: 1px solid color-mix(in oklab, var(--color-accent) 28%, transparent);
    border-radius: var(--radius-md);
    max-width: 52rem;
  }

  .activation-icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .activation-text {
    margin: 0;
    color: var(--color-text);
    font-size: 14px;
    line-height: 1.65;
  }

  .activation-text :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    padding: 1px 6px;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xs);
    color: var(--color-accent);
  }

  /* Install card */
  .install-card {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 52rem;
  }

  @media (min-width: 768px) {
    .install-card {
      padding: 28px;
    }
  }

  /* Tab strip */
  .tab-strip {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    flex-wrap: wrap;
  }

  .tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      color 200ms var(--ease-out-soft),
      background 200ms var(--ease-out-soft),
      border-color 200ms var(--ease-out-soft);
  }

  .tab:hover {
    color: var(--color-text);
  }

  .tab.active {
    color: var(--color-text);
    background: var(--color-raised);
    border-color: var(--color-border);
  }

  .tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .recommended-badge {
    font-size: 10px;
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent);
    border-radius: 999px;
    padding: 2px 6px;
    letter-spacing: 0.04em;
  }

  /* Panel */
  .panel {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .block-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .block-label {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .note {
    font-size: 12.5px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
