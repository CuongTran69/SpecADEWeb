---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
---
{/* TODO: replace with real screenshots from web/public/screenshots/ */}

<section id="screenshots" class="screenshots">
  <div class="container-wide">
    <header class="section-head">
      <span class="chip">{lang === 'vi' ? 'Giao diện' : 'Screenshots'}</span>
      <h2 class="section-title">{strings.screenshots.title}</h2>
      <p class="section-subtitle">{strings.screenshots.subtitle}</p>
    </header>

    <div class="screenshots-grid">
      {strings.screenshots.items.map((item, i) => (
        <div class="screenshot-card reveal" data-testid={`screenshot-placeholder-${i}`} aria-label={item.title}>
          <!-- TODO: replace with real screenshots from web/public/screenshots/ -->
          <div class="placeholder-inner" aria-hidden="true">
            <svg class="placeholder-pattern" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id={`hatch-${i}`} width="12" height="12" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                  <line x1="0" y1="0" x2="0" y2="12" stroke="currentColor" stroke-width="1" opacity="0.15"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill={`url(#hatch-${i})`}/>
            </svg>
            <div class="placeholder-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21,15 16,10 5,21"/>
              </svg>
            </div>
          </div>
          <div class="screenshot-label">
            <span class="screenshot-title">{item.title}</span>
            <span class="screenshot-todo">{lang === 'vi' ? 'Sắp có' : 'Coming soon'}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .screenshots {
    padding-block: clamp(64px, 8vw, 96px);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 48px;
    max-width: 42rem;
  }

  .screenshots-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 640px) {
    .screenshots-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .screenshots-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Make the 5th card span 2 columns on 3-col layout to fill the row */
  @media (min-width: 1024px) {
    .screenshot-card:nth-child(5) {
      grid-column: span 1;
    }
  }

  .screenshot-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    transition:
      border-color 200ms var(--ease-out-soft),
      transform 300ms var(--ease-out-soft);
  }

  .screenshot-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
  }

  .placeholder-inner {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-raised);
    color: var(--color-border-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .placeholder-pattern {
    position: absolute;
    inset: 0;
  }

  .placeholder-icon {
    position: relative;
    z-index: 1;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .screenshot-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--color-border);
  }

  .screenshot-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
  }

  .screenshot-todo {
    font-size: 11px;
    font-weight: 500;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
