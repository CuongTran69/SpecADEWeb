---
interface Props {
  id: string
  hook: string
  body: string
  flip?: boolean
  tone?: 'default' | 'accent'
  tag?: string
}

const { id, hook, body, flip = false, tone = 'default', tag } = Astro.props
---

<section class:list={['spotlight', `spotlight--${tone}`, flip && 'spotlight--flip']} data-testid={`spotlight-${id}`}>
  <div class="container-wide spotlight-inner">
    <div class="spotlight-visual">
      <slot name="visual" />
    </div>
    <div class="spotlight-copy">
      {tag && <span class="chip spotlight-tag">{tag}</span>}
      <h2 class="spotlight-hook">{hook}</h2>
      <p class="spotlight-body">{body}</p>
      <slot name="extra" />
    </div>
  </div>
</section>

<style>
  .spotlight {
    padding-block: clamp(72px, 9vw, 112px);
    border-block-end: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .spotlight--default {
    background: var(--color-bg);
  }

  .spotlight--accent {
    background: var(--color-surface);
  }

  .spotlight-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .spotlight-inner {
      grid-template-columns: 1fr 1fr;
      gap: 72px;
    }

    .spotlight--flip .spotlight-visual {
      order: 2;
    }
  }

  .spotlight-visual {
    min-width: 0;
  }

  .spotlight-copy {
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 38rem;
  }

  .spotlight-tag {
    align-self: flex-start;
  }

  .spotlight-hook {
    font-size: clamp(1.625rem, 3.2vw, 2.25rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0;
  }

  .spotlight-body {
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.4vw, 1.0625rem);
    line-height: 1.7;
    margin: 0;
  }
</style>
