---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import TerminalDemo from '~/components/islands/TerminalDemo.vue'
import Icon from '~/components/Icon.astro'
import CopyBlock from '~/components/CopyBlock.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
---

<section class="hero">
  <div class="hero-bg bg-grid" aria-hidden="true"></div>

  <div class="container-wide hero-inner">
    <div class="hero-copy fade-in-up">
      <div class="hero-badge-row">
        <span class="chip" data-testid="hero-badge">{strings.hero.badge}</span>
        <span class="hero-badge-sep" aria-hidden="true">·</span>
        <span class="hero-platform-note">{strings.hero.runningOn}</span>
      </div>

      <h1 class="hero-title">
        {strings.hero.titlePrefix}<span class="hero-title-accent">{strings.hero.titleAccent}</span>{strings.hero.titleSuffix}
      </h1>

      <p class="hero-subtitle">{strings.hero.subtitle}</p>

      <div class="hero-install">
        <div class="hero-install-header">
          <span class="hero-install-label">{strings.hero.installPrompt}</span>
          <span class="hero-coming-soon chip" data-testid="hero-coming-soon">{strings.hero.installComingSoon}</span>
        </div>
        <CopyBlock code="npx -y @spec-ade/cli@latest" />
      </div>

      <div class="hero-cta">
        <a href="#get-started" class="btn btn-primary hero-btn-primary" data-testid="hero-primary-cta">
          {strings.hero.primaryCta}
          <Icon name="arrow-right" size={14} />
        </a>
        <a href="#what-is-spec-ade" class="btn btn-secondary" data-testid="hero-secondary-cta">
          {strings.hero.secondaryCta}
        </a>
      </div>

      <div class="hero-trust" aria-label="Key stats">
        {strings.hero.trust.map((item, i) => (
          <>
            {i > 0 && <div class="hero-trust-divider" aria-hidden="true"></div>}
            <div class="hero-trust-item">
              <span class="hero-trust-value">{item.value}</span>
              <span class="hero-trust-label">{item.label}</span>
            </div>
          </>
        ))}
      </div>
    </div>

    <div class="hero-visual fade-in-up" style="animation-delay: 150ms">
      <TerminalDemo client:visible />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    padding-block: clamp(56px, 9vw, 112px) clamp(56px, 8vw, 96px);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.3;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 72px;
    }
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero-badge-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero-badge-sep {
    color: var(--color-border-strong);
    font-size: 16px;
  }

  .hero-platform-note {
    font-size: 12px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0;
  }

  .hero-title-accent {
    color: var(--color-accent);
  }

  .hero-subtitle {
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    line-height: 1.7;
    max-width: 38rem;
    margin: 0;
  }

  .hero-install {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 38rem;
  }

  .hero-install-header {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero-install-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .hero-coming-soon {
    background: color-mix(in oklab, var(--color-warning) 10%, transparent);
    color: var(--color-warning);
    border-color: color-mix(in oklab, var(--color-warning) 25%, transparent);
    font-size: 10px;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-btn-primary {
    font-size: 15px;
    padding: 12px 24px;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    padding-top: 4px;
  }

  .hero-trust-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-trust-value {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .hero-trust-label {
    font-size: 11px;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .hero-trust-divider {
    width: 1px;
    height: 28px;
    background: var(--color-border-strong);
    flex-shrink: 0;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-visual { justify-content: flex-end; }
  }
</style>
