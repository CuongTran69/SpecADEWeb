---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { altLang, pathFor, swapLangPath } from '~/i18n/utils'
import ThemeToggle from '~/components/islands/ThemeToggle.vue'
import BrandMark from '~/components/BrandMark.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
const otherLang = altLang(lang)
const currentPath = Astro.url.pathname
const otherPath = swapLangPath(currentPath, otherLang)

const homePath = pathFor(lang, '/')
---

<header class="site-header">
  <div class="container-wide header-inner">
    <a href={homePath} class="brand" aria-label="Spec ADE">
      <span class="brand-mark" aria-hidden="true">
        <BrandMark size={22} />
      </span>
      <span class="brand-text">Spec <span class="brand-ade">ADE</span></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      <a href={pathFor(lang, '/features')} class="nav-link">{strings.nav.features}</a>
      <a href={pathFor(lang, '/#pricing')} class="nav-link">{strings.nav.pricing}</a>
      <a href={pathFor(lang, '/install')} class="nav-link">{strings.nav.getStarted}</a>
      <a href={pathFor(lang, '/faq')} class="nav-link">{strings.nav.faq}</a>
    </nav>

    <div class="header-actions">
      <a href={otherPath} class="btn btn-ghost lang-link" hreflang={otherLang} data-testid="lang-switch">
        {strings.nav.switchTo}
      </a>
      <ThemeToggle client:load />
      <a
        href={pathFor(lang, '/install')}
        class="btn btn-primary header-cta"
        data-testid="header-cta"
      >
        {strings.nav.getStarted}
        <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
      <button
        type="button"
        class="nav-toggle"
        aria-controls="mobile-nav"
        aria-expanded="false"
        aria-label="Toggle menu"
        data-testid="nav-toggle"
        data-nav-toggle
      >
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="mobile-nav" hidden data-testid="mobile-nav">
    <nav class="mobile-nav-links" aria-label="Mobile primary">
      <a href={pathFor(lang, '/features')} data-testid="mobile-nav-link-features">{strings.nav.features}</a>
      <a href={pathFor(lang, '/#pricing')} data-testid="mobile-nav-link-pricing">{strings.nav.pricing}</a>
      <a href={pathFor(lang, '/install')} data-testid="mobile-nav-link-install">{strings.nav.getStarted}</a>
      <a href={pathFor(lang, '/faq')} data-testid="mobile-nav-link-faq">{strings.nav.faq}</a>
      <a href={pathFor(lang, '/install')} data-testid="mobile-nav-link-get-started" class="mobile-cta">{strings.nav.getStarted}</a>
      <a href={otherPath} hreflang={otherLang} class="mobile-lang-link">{strings.nav.switchTo}</a>
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    if (document.documentElement.dataset.navToggleInit === '1') return
    document.documentElement.dataset.navToggleInit = '1'

    if (!CSS.supports('(animation-timeline: scroll()) and (animation-range: 0% 100%)')) {
      const header = document.querySelector('.site-header')
      const inner = document.querySelector('.header-inner')
      if (header && inner) {
        window.addEventListener('scroll', () => {
          const isShrunk = window.scrollY > 40
          header.classList.toggle('site-header--shrunk', isShrunk)
          inner.classList.toggle('header-inner--shrunk', isShrunk)
        }, { passive: true })
      }
    }

    const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]')
    const mobileNav = document.getElementById('mobile-nav')

    function openMenu() {
      if (!toggle || !mobileNav) return
      mobileNav.hidden = false
      toggle.setAttribute('aria-expanded', 'true')
      document.documentElement.classList.add('nav-open')
    }

    function closeMenu() {
      if (!toggle || !mobileNav) return
      mobileNav.hidden = true
      toggle.setAttribute('aria-expanded', 'false')
      document.documentElement.classList.remove('nav-open')
    }

    if (toggle && mobileNav) {
      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true'
        if (isOpen) closeMenu()
        else openMenu()
      })

      mobileNav.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', closeMenu)
      })

      document.addEventListener('click', (e) => {
        const header = document.querySelector('.site-header')
        if (header && !header.contains(e.target as Node)) closeMenu()
      })

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
          closeMenu()
          toggle.focus()
        }
      })

      function trapFocus(e: KeyboardEvent) {
        if (e.key !== 'Tab') return
        if (toggle!.getAttribute('aria-expanded') !== 'true') return
        const focusable = Array.from(mobileNav!.querySelectorAll<HTMLElement>('a, button'))
        const allFocusable = [toggle!, ...focusable]
        if (allFocusable.length === 0) return
        const first = allFocusable[0]
        const last = allFocusable[allFocusable.length - 1]
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault()
          last?.focus()
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault()
          first?.focus()
        }
      }
      document.addEventListener('keydown', trapFocus)
    }
  }

  initHeader()
  document.addEventListener('astro:after-swap', initHeader)
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 75%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
    transition: background 250ms var(--ease-out-soft), border-color 250ms var(--ease-out-soft);
  }

  @keyframes header-shrink {
    to {
      background: color-mix(in oklab, var(--color-bg) 92%, transparent);
      border-color: var(--color-border-strong);
    }
  }

  @supports ((animation-timeline: scroll()) and (animation-range: 0% 100%)) {
    .site-header {
      animation: header-shrink auto linear both;
      animation-timeline: scroll(block root);
      animation-range: 0px 80px;
    }
  }

  .site-header--shrunk {
    background: color-mix(in oklab, var(--color-bg) 92%, transparent);
    border-color: var(--color-border-strong);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 60px;
    transition: height 250ms var(--ease-out-soft);
  }

  @keyframes inner-shrink {
    to { height: 48px; }
  }

  @supports ((animation-timeline: scroll()) and (animation-range: 0% 100%)) {
    .header-inner {
      animation: inner-shrink auto linear both;
      animation-timeline: scroll(block root);
      animation-range: 0px 80px;
    }
  }

  .header-inner--shrunk { height: 48px; }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 15px;
    flex-shrink: 0;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-md);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border: 1px solid color-mix(in oklab, var(--color-accent) 25%, transparent);
    transition: background 200ms var(--ease-out-soft);
  }

  .brand:hover .brand-mark {
    background: color-mix(in oklab, var(--color-accent) 18%, transparent);
  }

  .brand-ade { color: var(--color-accent); }

  .nav-links {
    display: none;
    gap: 2px;
    margin-left: auto;
  }

  .nav-link {
    padding: 7px 13px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 200ms var(--ease-out-soft), background 200ms var(--ease-out-soft);
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-raised);
  }

  .header-actions {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .lang-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
  }

  .header-cta {
    font-size: 13px;
    padding: 8px 16px;
  }

  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: color 150ms var(--ease-out-soft), background 150ms var(--ease-out-soft);
    flex-shrink: 0;
  }

  .nav-toggle:hover {
    color: var(--color-text);
    background: var(--color-raised);
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .mobile-nav {
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    background: color-mix(in oklab, var(--color-surface) 96%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md);
    z-index: 49;
  }

  .mobile-nav[hidden] { display: none; }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-nav-links a {
    display: block;
    padding: 11px 14px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: color 150ms var(--ease-out-soft), background 150ms var(--ease-out-soft);
  }

  .mobile-nav-links a:hover {
    color: var(--color-text);
    background: var(--color-raised);
  }

  .mobile-cta {
    color: var(--color-accent) !important;
    background: var(--color-accent-soft) !important;
    border: 1px solid color-mix(in oklab, var(--color-accent) 20%, transparent);
    margin-top: 4px;
  }

  .mobile-lang-link {
    font-family: var(--font-mono);
    font-size: 12px;
    margin-top: 4px;
    border-top: 1px solid var(--color-border);
    padding-top: 12px !important;
    color: var(--color-text-muted) !important;
  }

  @media (max-width: 767px) { .nav-toggle { display: inline-flex; } }

  @media (min-width: 768px) {
    .nav-links { display: inline-flex; }
    .header-actions { margin-left: 0; }
    .mobile-nav { display: none; }
  }

  @media (max-width: 480px) { .header-cta { display: none; } }

  :global(html.nav-open) { overflow: hidden; }
</style>
