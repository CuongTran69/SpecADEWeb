---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
const s = strings.portForwarding

const ADE_PORT = 4124
const ADE_PUBLIC_HOST = 'ade.spec-ade.dev'
const ADE_ACCESS_KEY = 'ade_key_6868_cf'
const ADE_LOCAL_URL = `localhost:${ADE_PORT}`
const ADE_PROXY_URL = `http://0.0.0.0:${ADE_PORT}`
const ADE_PUBLIC_URL = `https://${ADE_PUBLIC_HOST}`
---

<section class="port-forwarding" id="port-forwarding">
  <div class="container-wide">
    <header class="section-head reveal">
      <span class="chip">{s.chip}</span>
      <h2 class="section-title">{s.title}</h2>
      <p class="section-subtitle">{s.subtitle}</p>
    </header>

    <!-- Interactive 3-Column Panel -->
    <div class="pf-showcase reveal" id="pf-showcase-panel">
      <div class="pane-header">
        <h3 class="pf-column-title">{s.visualTitle}</h3>
        <p class="pf-column-desc">{s.visualSub}</p>
      </div>

      <div class="pf-grid">
        <!-- LEFT COLUMN: Port Settings -->
        <div class="pf-column settings-pane">
          <!-- Port Info Card -->
          <div class="port-info-card">
            <div class="port-info-header">
              <div class="port-info-icon">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
                </svg>
              </div>
              <div class="port-info-meta">
                <span class="port-info-name">Spec ADE Workspace</span>
                <span class="port-info-port">{`Port ${ADE_PORT}`}</span>
              </div>
              <span class="port-info-status status-offline" id="pf-status-badge">Offline</span>
            </div>

            <div class="port-detail-rows">
              <div class="detail-row">
                <span class="detail-label">{s.localPort}</span>
                <code class="detail-value">{ADE_LOCAL_URL}</code>
              </div>
              <div class="detail-row" id="pf-proxy-row" style="display: none;">
                <span class="detail-label">{s.proxyUrl}</span>
                <code class="detail-value text-cyan">{ADE_PROXY_URL}</code>
              </div>
              <div class="detail-row" id="pf-public-row" style="display: none;">
                <span class="detail-label">{s.publicUrl}</span>
                <code class="detail-value text-green">{ADE_PUBLIC_URL}</code>
              </div>
              <div class="detail-row" id="pf-key-row" style="display: none;">
                <span class="detail-label">{s.accessKey}</span>
                <div class="key-value-group">
                  <code class="detail-value text-amber" id="pf-key-value">{ADE_ACCESS_KEY}</code>
                  <button type="button" class="copy-key-btn" id="pf-copy-btn" data-copy-label={s.copyBtn} data-copied-label={s.copiedLabel}>
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    <span>{s.copyBtn}</span>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Toggle Controls -->
          <div class="toggle-controls">
            <label class="toggle-control" for="pf-toggle-forward">
              <div class="toggle-info">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15 3 21 3 21 9"/><path d="M21 3l-7 7"/>
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                </svg>
                <span>{s.forwardToggle}</span>
              </div>
              <div class="switch-wrapper">
                <input type="checkbox" id="pf-toggle-forward" class="switch-input" />
                <span class="switch-track"></span>
              </div>
            </label>

            <label class="toggle-control" for="pf-toggle-tunnel">
              <div class="toggle-info">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
                <span>{s.tunnelToggle}</span>
              </div>
              <div class="switch-wrapper">
                <input type="checkbox" id="pf-toggle-tunnel" class="switch-input" disabled />
                <span class="switch-track"></span>
              </div>
            </label>

            <label class="toggle-control" for="pf-toggle-key">
              <div class="toggle-info">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <span>{s.securityToggle}</span>
              </div>
              <div class="switch-wrapper">
                <input type="checkbox" id="pf-toggle-key" class="switch-input" disabled />
                <span class="switch-track"></span>
              </div>
            </label>
          </div>
        </div>

        <!-- MIDDLE COLUMN: Visual Gateway (desktop only) -->
        <div class="pf-column gateway-pane" aria-hidden="true">
          <div class="gateway-visual">
            <svg class="gateway-svg" viewBox="0 0 100 240" fill="none" preserveAspectRatio="xMidYMid meet">
              <path id="pf-path-1" class="gw-path" d="M 50,40 C 50,70 50,70 50,100" />
              <path id="pf-path-2" class="gw-path" d="M 50,140 C 50,170 50,170 50,200" />
              <g id="pf-lock-icon" class="gw-lock" transform="translate(35, 154)" style="display: none;">
                <rect x="2" y="6" width="12" height="10" rx="1.5" fill="var(--color-warning)" opacity="0.9"/>
                <path d="M5 6V4a3 3 0 0 1 6 0v2" fill="none" stroke="var(--color-warning)" stroke-width="1.5" stroke-linecap="round"/>
              </g>
            </svg>

            <div class="gw-node node-local" id="pf-node-local">
              <div class="gw-node-icon">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
                </svg>
              </div>
              <span class="gw-node-label">Spec ADE</span>
              <span class="gw-node-sub">{ADE_LOCAL_URL}</span>
            </div>

            <div class="gw-node node-cf" id="pf-node-cf">
              <div class="gw-node-icon icon-cf">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
              </div>
              <span class="gw-node-label">Cloudflare Edge</span>
              <span class="gw-node-sub">Encrypted Tunnel</span>
            </div>

            <div class="gw-node node-client" id="pf-node-client">
              <div class="gw-node-icon icon-client">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>
                </svg>
              </div>
              <span class="gw-node-label">Remote User</span>
              <span class="gw-node-sub">Any Browser</span>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: Remote Browser Mockup -->
        <div class="pf-column browser-pane">
          <div class="mock-browser" id="pf-browser">
            <div class="browser-bar">
              <div class="browser-dots"><span></span><span></span><span></span></div>
              <div class="browser-address-bar">
                <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lock-icon-bar" id="pf-bar-lock" style="display: none;">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <span class="address-text" id="pf-address-text">{ADE_PUBLIC_HOST}</span>
              </div>
            </div>

            <!-- State: Offline (default) -->
            <div class="browser-state state-offline" id="pf-state-offline">
              <div class="offline-icon">
                <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                </svg>
              </div>
              <h4 class="state-title">502</h4>
              <p class="state-label">{s.statusOffline}</p>
              <p class="state-desc">{s.statusOfflineDesc}</p>
            </div>

            <!-- State: Locked -->
            <div class="browser-state state-locked" id="pf-state-locked" style="display: none;">
              <div class="locked-icon">
                <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
              <h4 class="state-title">{s.statusLocked}</h4>
              <p class="state-desc">{s.statusLockedDesc}</p>
              <div class="key-input-group">
                <input type="text" class="key-input" id="pf-key-input" placeholder="ade_key_••••••" autocomplete="off" />
                <button type="button" class="autofill-btn" id="pf-autofill-btn">{s.autofillBtn}</button>
              </div>
              <button type="button" class="unlock-btn" id="pf-unlock-btn">{s.unlockBtn}</button>
              <p class="error-msg" id="pf-error-msg" style="display: none;">{s.wrongKey}</p>
            </div>

            <!-- State: Connected — ADE Workspace -->
            <div class="browser-state state-connected" id="pf-state-connected" style="display: none;">
              <div class="dash-header">
                <div class="dash-logo">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
                  </svg>
                  <span>{s.activeDashboard}</span>
                </div>
                <span class="dash-live-badge">● Live</span>
              </div>
              <!-- Mini ADE UI mockup: sidebar + terminal -->
              <div class="ade-workspace-mock">
                <div class="ade-sidebar">
                  <div class="ade-tree-item">📂 src/</div>
                  <div class="ade-tree-item sub">📄 main.rs</div>
                  <div class="ade-tree-item sub">📄 config.toml</div>
                  <div class="ade-tree-item">📂 agents/</div>
                  <div class="ade-tree-item sub active">🤖 claude.yaml</div>
                  <div class="ade-tree-item sub">🤖 codex.yaml</div>
                </div>
                <div class="ade-main-area">
                  <div class="ade-terminal-mini">
                    <div class="ade-term-line"><span class="term-prompt">$</span> ade agent run claude --goal "refactor auth"</div>
                    <div class="ade-term-line dim">⚡ Claude Code connected via ACP...</div>
                    <div class="ade-term-line dim">📝 Analyzing src/auth/handler.rs...</div>
                    <div class="ade-term-line success">✓ 3 files modified. All tests pass.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Panel: Start Simulation / Success -->
      <div class="showcase-actions">
        <button type="button" class="action-btn-start" id="pf-btn-start">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          {s.startSimulation}
        </button>

        <div class="success-banner-card" id="pf-success-banner" hidden>
          <span class="success-banner-text">{s.simSuccess}</span>
          <button type="button" class="action-btn-reset" id="pf-btn-reset">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
            {s.resetSimulation}
          </button>
        </div>
      </div>
    </div>

    <!-- Benefits Grid -->
    <div class="benefits-grid reveal">
      <div class="benefit-card shine-hover">
        <div class="benefit-icon-badge">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>
          </svg>
        </div>
        <h3 class="benefit-title">{s.benefitTitle1}</h3>
        <p class="benefit-desc">{s.benefitDesc1}</p>
      </div>

      <div class="benefit-card shine-hover">
        <div class="benefit-icon-badge" style="--badge-accent-color: #f97316">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <h3 class="benefit-title">{s.benefitTitle2}</h3>
        <p class="benefit-desc">{s.benefitDesc2}</p>
      </div>

      <div class="benefit-card shine-hover">
        <div class="benefit-icon-badge" style="--badge-accent-color: #eab308">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h3 class="benefit-title">{s.benefitTitle3}</h3>
        <p class="benefit-desc">{s.benefitDesc3}</p>
      </div>

      <div class="benefit-card shine-hover">
        <div class="benefit-icon-badge" style="--badge-accent-color: #10b981">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3 class="benefit-title">{s.benefitTitle4}</h3>
        <p class="benefit-desc">{s.benefitDesc4}</p>
      </div>
    </div>
  </div>
</section>

<script>
  function initPortForwarding() {
    const section = document.getElementById('port-forwarding');
    if (!section) return;

    const toggleForward = section.querySelector('#pf-toggle-forward') as HTMLInputElement | null;
    const toggleTunnel = section.querySelector('#pf-toggle-tunnel') as HTMLInputElement | null;
    const toggleKey = section.querySelector('#pf-toggle-key') as HTMLInputElement | null;

    const statusBadge = section.querySelector('#pf-status-badge') as HTMLElement | null;
    const proxyRow = section.querySelector('#pf-proxy-row') as HTMLElement | null;
    const publicRow = section.querySelector('#pf-public-row') as HTMLElement | null;
    const keyRow = section.querySelector('#pf-key-row') as HTMLElement | null;

    const path1 = section.querySelector('#pf-path-1') as SVGElement | null;
    const path2 = section.querySelector('#pf-path-2') as SVGElement | null;
    const lockIcon = section.querySelector('#pf-lock-icon') as SVGElement | null;
    const nodeLocal = section.querySelector('#pf-node-local') as HTMLElement | null;
    const nodeCf = section.querySelector('#pf-node-cf') as HTMLElement | null;
    const nodeClient = section.querySelector('#pf-node-client') as HTMLElement | null;

    const barLock = section.querySelector('#pf-bar-lock') as SVGElement | null;
    const stateOffline = section.querySelector('#pf-state-offline') as HTMLElement | null;
    const stateLocked = section.querySelector('#pf-state-locked') as HTMLElement | null;
    const stateConnected = section.querySelector('#pf-state-connected') as HTMLElement | null;

    const keyInput = section.querySelector('#pf-key-input') as HTMLInputElement | null;
    const autofillBtn = section.querySelector('#pf-autofill-btn') as HTMLButtonElement | null;
    const unlockBtn = section.querySelector('#pf-unlock-btn') as HTMLButtonElement | null;
    const errorMsg = section.querySelector('#pf-error-msg') as HTMLElement | null;
    const copyBtn = section.querySelector('#pf-copy-btn') as HTMLButtonElement | null;

    const startBtn = section.querySelector('#pf-btn-start') as HTMLButtonElement | null;
    const resetBtn = section.querySelector('#pf-btn-reset') as HTMLButtonElement | null;
    const successBanner = section.querySelector('#pf-success-banner') as HTMLElement | null;

    const keyValueEl = section.querySelector('#pf-key-value') as HTMLElement | null;
    const ACCESS_KEY = (keyValueEl?.textContent || '').trim();
    let simTimeouts: number[] = [];
    let simRunning = false;

    type BrowserState = 'offline' | 'locked' | 'connected';

    function setBrowserState(state: BrowserState) {
      if (stateOffline) stateOffline.style.display = state === 'offline' ? '' : 'none';
      if (stateLocked) stateLocked.style.display = state === 'locked' ? '' : 'none';
      if (stateConnected) stateConnected.style.display = state === 'connected' ? '' : 'none';
      if (errorMsg) errorMsg.style.display = 'none';
      if (keyInput) keyInput.value = '';
    }

    function updateState() {
      if (!toggleForward || !toggleTunnel || !toggleKey) return;

      const isForwarded = toggleForward.checked;
      const isTunneled = toggleTunnel.checked;

      toggleTunnel.disabled = !isForwarded;
      toggleKey.disabled = !isTunneled;

      if (!isForwarded) {
        toggleTunnel.checked = false;
        toggleKey.checked = false;
      }
      if (!isTunneled) {
        toggleKey.checked = false;
      }

      const fwd = toggleForward.checked;
      const tun = toggleTunnel.checked;
      const sec = toggleKey.checked;

      if (proxyRow) proxyRow.style.display = fwd ? '' : 'none';
      if (publicRow) publicRow.style.display = tun ? '' : 'none';
      if (keyRow) keyRow.style.display = sec ? '' : 'none';

      if (statusBadge) {
        if (!fwd) {
          statusBadge.textContent = 'Offline';
          statusBadge.className = 'port-info-status status-offline';
        } else if (!tun) {
          statusBadge.textContent = 'Local Only';
          statusBadge.className = 'port-info-status status-local';
        } else if (sec) {
          statusBadge.textContent = '🔒 Secured';
          statusBadge.className = 'port-info-status status-secured';
        } else {
          statusBadge.textContent = '● Public';
          statusBadge.className = 'port-info-status status-public';
        }
      }

      if (path1) path1.classList.toggle('active', fwd);
      if (path2) path2.classList.toggle('active', tun);
      if (lockIcon) lockIcon.style.display = sec ? '' : 'none';
      if (nodeLocal) nodeLocal.classList.toggle('active', fwd);
      if (nodeCf) nodeCf.classList.toggle('active', tun);
      if (nodeClient) nodeClient.classList.toggle('active', tun);

      if (barLock) barLock.style.display = tun ? '' : 'none';

      if (!tun) {
        setBrowserState('offline');
      } else if (sec) {
        setBrowserState('locked');
      } else {
        setBrowserState('connected');
      }
    }

    // Wire toggles for manual use
    toggleForward?.addEventListener('change', updateState);
    toggleTunnel?.addEventListener('change', updateState);
    toggleKey?.addEventListener('change', updateState);

    // Autofill
    autofillBtn?.addEventListener('click', () => {
      if (keyInput) {
        keyInput.value = ACCESS_KEY;
        keyInput.classList.add('filled');
        setTimeout(() => keyInput.classList.remove('filled'), 300);
      }
    });

    // Unlock
    unlockBtn?.addEventListener('click', () => {
      if (!keyInput) return;
      if (keyInput.value === ACCESS_KEY) {
        setBrowserState('connected');
      } else {
        if (errorMsg) errorMsg.style.display = '';
        keyInput.classList.add('shake');
        setTimeout(() => keyInput.classList.remove('shake'), 500);
      }
    });

    keyInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') unlockBtn?.click();
    });

    // Copy
    copyBtn?.addEventListener('click', () => {
      const keyValue = section.querySelector('#pf-key-value')?.textContent || ACCESS_KEY;
      navigator.clipboard.writeText(keyValue).catch(() => {});
      const labelSpan = copyBtn.querySelector('span');
      const copiedLabel = copyBtn.getAttribute('data-copied-label') || 'Copied!';
      const copyLabel = copyBtn.getAttribute('data-copy-label') || 'Copy';
      if (labelSpan) {
        labelSpan.textContent = copiedLabel;
        copyBtn.classList.add('copied');
        setTimeout(() => {
          labelSpan.textContent = copyLabel;
          copyBtn.classList.remove('copied');
        }, 1500);
      }
    });

    // ===== Simulation =====
    function resetAll() {
      simTimeouts.forEach(id => clearTimeout(id));
      simTimeouts = [];
      simRunning = false;

      if (toggleForward) { toggleForward.checked = false; }
      if (toggleTunnel) { toggleTunnel.checked = false; toggleTunnel.disabled = true; }
      if (toggleKey) { toggleKey.checked = false; toggleKey.disabled = true; }
      updateState();

      if (startBtn) startBtn.hidden = false;
      if (successBanner) successBanner.hidden = true;
    }

    function schedule(fn: () => void, delay: number) {
      const id = window.setTimeout(fn, delay);
      simTimeouts.push(id);
    }

    function runSimulation() {
      if (simRunning) return;
      simRunning = true;

      if (startBtn) startBtn.hidden = true;

      // Step 1: Enable Forward Port (800ms)
      schedule(() => {
        if (toggleForward) { toggleForward.checked = true; }
        updateState();
      }, 800);

      // Step 2: Enable Cloudflare Tunnel (2200ms)
      schedule(() => {
        if (toggleTunnel) { toggleTunnel.checked = true; }
        updateState();
      }, 2200);

      // Step 3: Enable Access Key (3600ms)
      schedule(() => {
        if (toggleKey) { toggleKey.checked = true; }
        updateState();
      }, 3600);

      // Step 4: Autofill key (5000ms)
      schedule(() => {
        if (keyInput) {
          keyInput.value = ACCESS_KEY;
          keyInput.classList.add('filled');
          setTimeout(() => keyInput.classList.remove('filled'), 300);
        }
      }, 5000);

      // Step 5: Unlock (6200ms)
      schedule(() => {
        setBrowserState('connected');
      }, 6200);

      // Step 6: Show success banner (7500ms)
      schedule(() => {
        simRunning = false;
        if (successBanner) successBanner.hidden = false;
      }, 7500);
    }

    startBtn?.addEventListener('click', runSimulation);
    resetBtn?.addEventListener('click', resetAll);
  }

  initPortForwarding();
  document.addEventListener('astro:after-swap', initPortForwarding);
</script>

<style>
  .port-forwarding {
    padding-block: clamp(64px, 8vw, 100px);
    background: var(--color-bg);
