---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'
import CopyBlock from '~/components/CopyBlock.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const title = lang === 'vi' ? 'Sẵn sàng lập trình cùng AI?' : 'Ready to build with AI?'
const subtitle = lang === 'vi' 
  ? 'Cài đặt Spec ADE bằng một dòng lệnh duy nhất trên máy tính của bạn.' 
  : 'Install Spec ADE with a single command on your machine.'
---

<section class="install-cta" id="install-cta">
  <div class="container-narrow">
    <div class="cta-card surface reveal">
      <header class="cta-header">
        <h2 class="section-title cta-title">{title}</h2>
        <p class="section-subtitle cta-subtitle">{subtitle}</p>
      </header>

      <div class="command-box">
        <CopyBlock code="npx -y @spec-ade/cli@latest" />
      </div>

      <div class="cta-actions">
        <a href={pathFor(lang, '/install')} class="btn btn-secondary" data-testid="full-install-guide-btn">
          {lang === 'vi' ? 'Xem hướng dẫn chi tiết (VPS, Node.js...) →' : 'View full installation guide (VPS, Node.js...) →'}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .install-cta {
    padding-block: clamp(64px, 8vw, 100px);
    background: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  .cta-card {
    padding: clamp(24px, 5vw, 48px);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 32px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  .cta-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    max-width: 36rem;
  }

  .cta-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin: 0;
  }

  .cta-subtitle {
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  .command-box {
    width: 100%;
    max-width: 440px;
    text-align: left;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
  }
</style>
