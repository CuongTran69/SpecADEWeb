---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
const p = strings.pricing
const ctaHref = pathFor(lang, '/install')
---

<section class="pricing-section" id="pricing">
  <div class="container-wide">
    <header class="section-head reveal">
      <span class="chip">{p.chip}</span>
      <h2 class="section-title">{p.title}</h2>
      <p class="section-subtitle">{p.subtitle}</p>
    </header>

    <div class="pricing-grid-simple reveal">
      <!-- Card 1: Free Core Plan -->
      <div class="pricing-card pricing-card--free">
        <span class="plan-badge plan-badge--active">{p.freePlan.badge}</span>

        <div class="plan-header">
          <h3 class="plan-name">{p.freePlan.name}</h3>
          <div class="plan-price-row">
            <span class="plan-price plan-price-highlight">{p.freePlan.price}</span>
            <span class="plan-period">{p.freePlan.period}</span>
          </div>
          <p class="plan-desc">{p.freePlan.desc}</p>
        </div>

        <div class="divider"></div>

        <ul class="plan-features">
          {p.freePlan.features.map((f) => (
            <li class="plan-feature-item">
              <span class="check-icon-wrapper check-icon-wrapper--free">
                <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="3.5 8.5 6.5 11.5 12.5 4.5" />
                </svg>
              </span>
              <span>{f}</span>
            </li>
          ))}
        </ul>

        <div class="divider"></div>

        <a href={ctaHref} class="cta-link cta-link--primary">
          {p.freePlan.ctaText}
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="arrow-icon">
            <polyline points="6 3 11 8 6 13" />
          </svg>
        </a>
      </div>

      <!-- Card 2: Gateway AI Plan (Coming Soon) -->
      <div class="pricing-card pricing-card--soon">
        <span class="plan-badge plan-badge--soon">{p.premiumPlan.badge}</span>

        <div class="plan-header">
          <h3 class="plan-name">{p.premiumPlan.name}</h3>
          <div class="plan-price-row">
            <span class="plan-price">{p.premiumPlan.price}</span>
            <span class="plan-period">{p.premiumPlan.period}</span>
          </div>
          <p class="plan-desc">{p.premiumPlan.desc}</p>
        </div>

        <div class="divider"></div>

        <ul class="plan-features">
          {p.premiumPlan.features.map((f) => (
            <li class="plan-feature-item">
              <span class="check-icon-wrapper check-icon-wrapper--soon">
                <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="3.5 8.5 6.5 11.5 12.5 4.5" />
                </svg>
              </span>
              <span>{f}</span>
            </li>
          ))}
        </ul>

        <div class="divider"></div>

        <button type="button" class="cta-btn-disabled" disabled>
          {p.premiumPlan.ctaText}
        </button>
      </div>
    </div>

    <!-- Bottom Note -->
    <p class="pricing-note reveal">{p.note}</p>
  </div>
</section>

<style>
  .pricing-section {
    padding-block: clamp(64px, 8vw, 100px);
    background: var(--color-bg);
    border-block-end: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 48px;
    max-width: 44rem;
    position: relative;
    z-index: 2;
  }

  /* Two Column Simple Centered Grid */
  .pricing-grid-simple {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 860px;
    margin-inline: auto;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 680px) {
    .pricing-grid-simple {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  /* Cards */
  .pricing-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: relative;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .pricing-card--free {
    border-color: var(--color-accent);
  }

  .pricing-card--soon {
    opacity: 0.95;
  }

  /* Badges */
  .plan-badge {
    position: absolute;
    top: 16px;
    right: 20px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 99px;
  }

  .plan-badge--active {
    background: color-mix(in oklab, var(--color-success) 12%, transparent);
    color: var(--color-success);
    border: 1px solid color-mix(in oklab, var(--color-success) 40%, transparent);
  }

  .plan-badge--soon {
    background: var(--color-raised);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  /* Plan header */
  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .plan-name {
    font-size: 24px;
    font-weight: 800;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    min-height: 40px;
  }

  .plan-price {
    font-size: 36px;
    font-weight: 900;
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .plan-price-highlight {
    color: var(--color-text);
  }

  .plan-period {
    font-size: 14px;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .plan-desc {
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    min-height: 60px;
  }

  .divider {
    height: 1px;
    background: var(--color-border);
  }

  /* Features list */
  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .plan-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .check-icon-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .check-icon-wrapper--free {
    background: rgba(34, 211, 238, 0.1);
    color: var(--color-accent);
    border: 1px solid rgba(34, 211, 238, 0.25);
  }

  .check-icon-wrapper--soon {
    background: var(--color-raised);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  /* CTA Actions */
  .cta-link {
    width: 100%;
    padding: 12px 16px;
    border-radius: var(--radius-lg);
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
    transition: all 150ms var(--ease-out-soft);
    font-family: var(--font-sans);
  }

  .cta-link--primary {
    background: var(--color-accent);
    color: #080810;
    border: 1px solid var(--color-accent);
  }

  .cta-link--primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    box-shadow: 0 4px 16px rgba(34, 211, 238, 0.15);
  }

  .cta-link .arrow-icon {
    transition: transform 150ms var(--ease-out-soft);
  }

  .cta-link:hover .arrow-icon {
    transform: translateX(2px);
  }

  .cta-btn-disabled {
    width: 100%;
    padding: 12px 16px;
    border-radius: var(--radius-lg);
    font-size: 14px;
    font-weight: 700;
    cursor: not-allowed;
    border: 1px solid var(--color-border);
    background: var(--color-raised);
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
  }

  /* Bottom Note */
  .pricing-note {
    text-align: center;
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 48px;
    max-width: 600px;
    margin-inline: auto;
    line-height: 1.6;
    position: relative;
    z-index: 2;
  }
</style>
