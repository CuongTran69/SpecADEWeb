---
interface Props {
  code: string
}

const { code } = Astro.props
---

<div class="copy-block" data-copy-block>
  <pre class="copy-pre"><code>{code}</code></pre>
  <button type="button" class="copy-btn" aria-label="Copy" title="Copy" data-copy-trigger>
    <svg class="icon-copy" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="5" y="5" width="9" height="9" rx="1.5"/>
      <path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5"/>
    </svg>
    <svg class="icon-check" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
      <path d="M3 8l4 4 6-7"/>
    </svg>
  </button>
  <span class="sr-only" aria-live="polite" data-copy-status></span>
</div>

<script>
  function initCopyBlocks() {
    document.querySelectorAll<HTMLElement>('[data-copy-block]').forEach((block) => {
      if (block.dataset.copyInit === '1') return
      block.dataset.copyInit = '1'

      const btn = block.querySelector<HTMLButtonElement>('[data-copy-trigger]')
      const pre = block.querySelector('pre')
      const statusEl = block.querySelector<HTMLElement>('[data-copy-status]')
      if (!btn || !pre) return

      const iconCopy = btn.querySelector<SVGElement>('.icon-copy')
      const iconCheck = btn.querySelector<SVGElement>('.icon-check')

      btn.addEventListener('click', async () => {
        const text = pre.textContent ?? ''
        try {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text)
          } else {
            const ta = document.createElement('textarea')
            ta.value = text
            ta.setAttribute('readonly', '')
            ta.style.cssText = 'position:fixed;left:-9999px'
            document.body.appendChild(ta)
            ta.select()
            document.execCommand('copy')
            document.body.removeChild(ta)
          }
        } catch { /* ignore */ }

        if (iconCopy) iconCopy.style.display = 'none'
        if (iconCheck) iconCheck.style.display = ''
        btn.setAttribute('aria-label', 'Copied')
        if (statusEl) statusEl.textContent = 'Copied'
        setTimeout(() => {
          if (iconCopy) iconCopy.style.display = ''
          if (iconCheck) iconCheck.style.display = 'none'
          btn.setAttribute('aria-label', 'Copy')
          if (statusEl) statusEl.textContent = ''
        }, 1600)
      })
    })
  }

  initCopyBlocks()
  document.addEventListener('astro:after-swap', initCopyBlocks)
</script>

<style>
  .copy-block {
    position: relative;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .copy-pre {
    margin: 0;
    padding: 14px 48px 14px 16px;
    overflow-x: auto;
    color: var(--color-text);
    line-height: 1.6;
    white-space: pre;
  }

  .copy-pre code {
    font-family: inherit;
  }

  .copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition:
      background 200ms var(--ease-out-soft),
      color 200ms var(--ease-out-soft);
  }

  .copy-btn:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .copy-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
