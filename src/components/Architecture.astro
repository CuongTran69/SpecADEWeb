---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const layers = [
  { id: 'frontend', title: strings.architecture.frontend, desc: strings.architecture.frontendDesc, label: 'Vue 3 + Quasar v2 + Pinia', tag: 'UI', color: 'var(--color-persona-2)' },
  { id: 'backend', title: strings.architecture.backend, desc: strings.architecture.backendDesc, label: 'Rust 2024 · Axum · tokio', tag: 'API', color: 'var(--color-accent)' },
  { id: 'storage', title: strings.architecture.storage, desc: strings.architecture.storageDesc, label: 'settings.json · OS keychain', tag: 'DATA', color: 'var(--color-persona-4)' },
]
---

<section id="architecture" class="arch">
  <div class="container-wide">
    <header class="section-head reveal">
      <span class="chip">Architecture</span>
      <h2 class="section-title">{strings.architecture.title}</h2>
      <p class="section-subtitle">{strings.architecture.subtitle}</p>
    </header>

    <div class="layout">
      <div class="layers">
        {layers.map((layer, i) => (
          <article class="layer reveal" data-testid={`arch-layer-${layer.id}`} style={`animation-delay:${i * 80}ms`}>
            <div class="layer-bar">
              <span class="layer-tag" style={`color: ${layer.color}; border-color: color-mix(in oklab, ${layer.color} 25%, transparent); background: color-mix(in oklab, ${layer.color} 10%, transparent)`}>{layer.tag}</span>
              <code class="layer-stack">{layer.label}</code>
            </div>
            <h3 class="layer-title">{layer.title}</h3>
            <p class="layer-desc">{layer.desc}</p>
            <div class="layer-accent" style={`background: ${layer.color}`} aria-hidden="true"></div>
          </article>
        ))}
      </div>

      <aside class="protocols surface reveal" aria-label="Protocols">
        <header class="protocols-head">
          <span class="chip">{strings.architecture.chip}</span>
        </header>
        <ul class="protocol-list">
          {strings.architecture.protocols.map((p) => (
            <li class="protocol-item">
              <span class="proto-name">{p.name}</span>
              <span class="proto-desc">{p.desc}</span>
            </li>
          ))}
        </ul>
        <div class="numbers">
          {strings.architecture.metrics.map((m) => (
            <div class="metric">
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .arch {
    padding-block: clamp(72px, 9vw, 112px);
    background: var(--color-bg);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 56px;
    max-width: 44rem;
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 1024px) {
    .layout {
      grid-template-columns: 1.5fr 1fr;
      gap: 32px;
    }
  }

  .layers {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .layer {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
    transition: border-color 250ms var(--ease-out-soft), transform 250ms var(--ease-out-soft);
  }

  .layer:hover {
    border-color: var(--color-border-strong);
    transform: translateX(4px);
  }

  .layer-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 2px 0 0 2px;
    opacity: 0.7;
  }

  .layer-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .layer-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid;
  }

  .layer-stack {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    background: var(--color-raised);
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .layer-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin: 0;
  }

  .layer-desc {
    color: var(--color-text-secondary);
    font-size: 13.5px;
    line-height: 1.65;
    margin: 0;
  }

  /* Protocols panel */
  .protocols {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-radius: var(--radius-xl);
  }

  .protocols-head {
    display: flex;
    align-items: center;
  }

  .protocol-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .protocol-item {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 11px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .protocol-item:last-child { border-bottom: none; }

  .proto-name {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 90px;
  }

  .proto-desc {
    font-size: 12.5px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .numbers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .metric-label {
    font-size: 11px;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
</style>
