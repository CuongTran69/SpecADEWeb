---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const layers = [
  { id: 'frontend', title: strings.architecture.frontend, desc: strings.architecture.frontendDesc, label: 'Vue 3 + Quasar v2 + Pinia', tag: 'UI' },
  { id: 'backend', title: strings.architecture.backend, desc: strings.architecture.backendDesc, label: 'Rust 2024 · Axum · tokio', tag: 'API' },
  { id: 'storage', title: strings.architecture.storage, desc: strings.architecture.storageDesc, label: 'settings.json · OS keychain', tag: 'DATA' },
]

const protocols = [
  { name: 'REST', desc: 'CRUD, git, settings, files, search' },
  { name: 'WebSocket', desc: 'PTY I/O, ACP relay, DB streaming' },
  { name: 'SSE', desc: 'Git change events, watch streams' },
  { name: 'Proxy', desc: '/fw/{port}/{*rest} forwards HTTP + WS' },
]
---

<section id="architecture" class="arch">
  <div class="container-wide">
    <header class="section-head">
      <h2 class="section-title">{strings.architecture.title}</h2>
      <p class="section-subtitle">{strings.architecture.subtitle}</p>
    </header>

    <div class="layout">
      <div class="layers">
        {layers.map((layer, i) => (
          <article class="layer reveal" data-testid={`arch-layer-${layer.id}`} style={`animation-delay:${i * 80}ms`}>
            <div class="layer-bar" aria-hidden="true">
              <span class="layer-tag">{layer.tag}</span>
              <code class="layer-stack">{layer.label}</code>
            </div>
            <h3 class="layer-title">{layer.title}</h3>
            <p class="layer-desc">{layer.desc}</p>
          </article>
        ))}
      </div>

      <aside class="protocols surface" aria-label="Protocols">
        <header class="protocols-head">
          <span class="chip">{strings.architecture.chip}</span>
        </header>
        <ul class="protocol-list">
          {protocols.map((p) => (
            <li class="protocol-item">
              <span class="proto-name">{p.name}</span>
              <span class="proto-desc">{p.desc}</span>
            </li>
          ))}
        </ul>
        <div class="numbers">
          <div class="metric">
            <span class="metric-value">17.9k</span>
            <span class="metric-label">symbols</span>
          </div>
          <div class="metric">
            <span class="metric-value">300</span>
            <span class="metric-label">execution flows</span>
          </div>
          <div class="metric">
            <span class="metric-value">30.6k</span>
            <span class="metric-label">relationships</span>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .arch {
    padding-block: clamp(64px, 8vw, 96px);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 48px;
    max-width: 42rem;
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 1024px) {
    .layout {
      grid-template-columns: 1.5fr 1fr;
      gap: 32px;
    }
  }

  .layers {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .layer {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .layer-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .layer-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    padding: 3px 8px;
    border-radius: 999px;
    color: var(--color-text-muted);
  }

  .layer-stack {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    background: var(--color-raised);
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .layer-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .layer-desc {
    color: var(--color-text-secondary);
    font-size: 14px;
    line-height: 1.65;
  }

  .protocols {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .protocols-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .protocol-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .protocol-item {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--color-border);
  }

  .protocol-item:last-child {
    border-bottom: none;
  }

  .proto-name {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 88px;
  }

  .proto-desc {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .numbers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .metric-label {
    font-size: 11px;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
</style>
