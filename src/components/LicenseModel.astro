---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
---

<section id="license" class="license-model" data-testid="license-section">
  <div class="container-wide">
    <div class="license-inner">
      <span class="chip">{strings.licenseModel.chip}</span>
      <div class="license-body">
        <h2 class="license-title">{strings.licenseModel.title}</h2>
        <p class="license-text">{strings.licenseModel.body}</p>
      </div>
      <a href={`${pathFor(lang, '/')}#faq`} class="btn btn-secondary license-link">
        {strings.licenseModel.faqLink}
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .license-model {
    padding-block: clamp(40px, 5vw, 64px);
    border-block: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .license-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .license-inner {
      flex-direction: row;
      align-items: center;
      gap: 24px;
    }
  }

  .license-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .license-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .license-text {
    color: var(--color-text-secondary);
    font-size: 14px;
    line-height: 1.6;
    max-width: 52rem;
    margin: 0;
  }

  .license-link {
    flex-shrink: 0;
  }
</style>
