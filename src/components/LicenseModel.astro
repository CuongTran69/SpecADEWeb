---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)
---

<section id="license" class="license-model" data-testid="license-section">
  <div class="container-wide">
    <div class="license-inner reveal">
      <div class="license-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div class="license-content">
        <div class="license-meta">
          <span class="chip">{strings.licenseModel.chip}</span>
        </div>
        <h2 class="license-title">{strings.licenseModel.title}</h2>
        <p class="license-text">{strings.licenseModel.body}</p>
      </div>
      <a href={`${pathFor(lang, '/')}#faq`} class="btn btn-secondary license-link">
        {strings.licenseModel.faqLink}
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .license-model {
    padding-block: clamp(48px, 6vw, 72px);
    border-block-start: 1px solid var(--color-border);
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
  }


  .license-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-2xl);
    padding: 32px 36px;
    max-width: 64rem;
  }

  @media (min-width: 768px) {
    .license-inner {
      flex-direction: row;
      align-items: center;
      gap: 28px;
    }
  }

  .license-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-xl);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border: 1px solid color-mix(in oklab, var(--color-accent) 25%, transparent);
    flex-shrink: 0;
  }

  .license-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .license-meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .license-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .license-text {
    color: var(--color-text-secondary);
    font-size: 14px;
    line-height: 1.65;
    max-width: 52rem;
    margin: 0;
  }

  .license-link {
    flex-shrink: 0;
    white-space: nowrap;
  }
</style>
