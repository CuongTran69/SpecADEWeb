---
import type { Lang } from '~/i18n/strings'
import { t } from '~/i18n/strings'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const strings = t(lang)

const accentVars = ['--color-persona-1', '--color-persona-2', '--color-persona-3', '--color-persona-4']

const icons = [
  `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/></svg>`,
  `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
  `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h10M7 12h6"/></svg>`,
  `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
]
---

<section class="usecases">
  <div class="container-wide">
    <header class="section-head reveal">
      <h2 class="section-title">{strings.useCases.title}</h2>
    </header>

    <div class="grid">
      {strings.useCases.items.map((item, i) => (
        <article class="uc-card glow-card reveal shine-hover" data-testid={`use-case-${i}`} style={`animation-delay:${i * 70}ms`}>
          <div class="uc-icon" style={`color: var(${accentVars[i % accentVars.length]}); background: color-mix(in oklab, var(${accentVars[i % accentVars.length]}) 10%, transparent); border-color: color-mix(in oklab, var(${accentVars[i % accentVars.length]}) 20%, transparent)`} set:html={icons[i % icons.length]}></div>
          <h3 class="uc-role">{item.role}</h3>
          <p class="uc-desc">{item.desc}</p>
          <div class="uc-bar" style={`background: var(${accentVars[i % accentVars.length]})`} aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .usecases {
    padding-block: clamp(56px, 7vw, 88px);
    background: var(--color-bg);
  }

  .section-head {
    margin-bottom: 44px;
    max-width: 44rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  @media (min-width: 640px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .grid { grid-template-columns: repeat(4, 1fr); }
  }

  .uc-card {
    position: relative;
    padding: 26px 24px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 250ms var(--ease-out-soft), transform 250ms var(--ease-out-soft), box-shadow 250ms var(--ease-out-soft);
  }

  .uc-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-3px);
  }

  .uc-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    opacity: 0.6;
  }

  .uc-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-lg);
    border: 1px solid;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .uc-role {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1.3;
  }

  .uc-desc {
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }
</style>
