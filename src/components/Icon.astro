---
interface Props {
  name: 'arrow-right' | 'chevron-down' | 'lock' | 'external-link' | 'copy' | 'check'
  size?: number
  strokeWidth?: number
  class?: string
}

const { name, size = 14, strokeWidth = 1.75, class: className } = Astro.props

const paths: Record<string, string> = {
  'arrow-right': `<path d="M3 8h10M9 4l4 4-4 4"/>`,
  'chevron-down': `<path d="M4 6l4 4 4-4"/>`,
  'lock': `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>`,
  'external-link': `<path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>`,
  'copy': `<rect x="5" y="5" width="9" height="9" rx="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5"/>`,
  'check': `<path d="M3 8l4 4 6-7"/>`,
}

// lock and external-link use viewBox 0 0 24 24; others use 0 0 16 16
const viewBox = (name === 'lock' || name === 'external-link') ? '0 0 24 24' : '0 0 16 16'
---

<svg
  class={className}
  viewBox={viewBox}
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={paths[name] ?? ''}
/>
