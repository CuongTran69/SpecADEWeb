---
import type { Lang } from '~/i18n/strings'
import { pathFor } from '~/i18n/utils'

interface Props {
  lang: Lang
  title: string
  subtitle?: string
  homeHref?: string
  backLabel?: string
}

const { lang, title, subtitle, homeHref, backLabel = 'Back to home' } = Astro.props
const resolvedHomeHref = homeHref ?? pathFor(lang, '/')

// Strip any leading arrow characters from the label (e.g. "← Back to home")
const cleanLabel = backLabel.replace(/^[←\->\s]+/, '').trim()
---

<div class="subpage-header">
  <div class="container-wide">
    <a href={resolvedHomeHref} class="back-link" data-testid="back-to-home">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M13 8H3M7 4l-4 4 4 4"/>
      </svg>
      {cleanLabel}
    </a>
    <h1 class="subpage-title">{title}</h1>
    {subtitle && <p class="subpage-subtitle">{subtitle}</p>}
  </div>
</div>

<style>
  .subpage-header {
    padding-block: clamp(32px, 5vw, 56px) clamp(24px, 3vw, 40px);
    border-bottom: 1px solid var(--color-border);
  }

  .container-wide {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms var(--ease-out-soft);
    width: fit-content;
  }

  .back-link:hover { color: var(--color-text); }
  .back-link svg { flex-shrink: 0; }

  .subpage-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin: 0;
    line-height: 1.1;
  }

  .subpage-subtitle {
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.4vw, 1.0625rem);
    line-height: 1.65;
    margin: 0;
    max-width: 44rem;
  }
</style>
